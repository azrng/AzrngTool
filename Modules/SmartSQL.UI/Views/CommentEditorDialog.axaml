<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SmartSQL.UI.ViewModels"
        mc:Ignorable="d"
        x:Class="SmartSQL.UI.Views.CommentEditorDialog"
        x:CompileBindings="False"
        x:DataType="vm:CommentEditorDialogViewModel"
        Title="{Binding DialogTitle}"
        Width="640"
        Height="560"
        MinWidth="620"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Icon="/Assets/avalonia-logo.ico">

    <Design.DataContext>
        <vm:CommentEditorDialogViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.commentEditorSurface">
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>

        <Style Selector="Border.commentSection">
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style Selector="TextBlock.commentFieldLabel">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        </Style>

        <Style Selector="TextBlock.commentFieldValue">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.commentSectionTitle">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>

        <Style Selector="TextBlock.commentSectionHint">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBox.commentEditorInput">
            <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Height" Value="112" />
            <Setter Property="MinHeight" Value="112" />
            <Setter Property="MaxHeight" Value="112" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>

        <Style Selector="Border.commentFooter">
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Padding" Value="0,16,0,0" />
        </Style>

        <Style Selector="Border.commentErrorBanner">
            <Setter Property="Background" Value="{DynamicResource Brush.Status.Error.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Danger}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="TextBlock.commentErrorText">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error.Text}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBlock.commentFooterTip">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="Button.commentFooterButton">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
        </Style>
    </Window.Styles>

    <Grid Background="{DynamicResource Brush.Background.App}">
        <Border Margin="16"
                Padding="20"
                Classes="commentEditorSurface">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding DialogTitle}"
                               Classes="heading" />
                    <TextBlock Text="{Binding HintText}"
                               Classes="caption"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="14">
                        <Border Classes="commentSection"
                                Padding="16,14">
                            <StackPanel Spacing="12">
                                <TextBlock Text="对象信息"
                                           Classes="commentSectionTitle" />

                                <Grid ColumnDefinitions="92,*"
                                      ColumnSpacing="12">
                                    <TextBlock Text="{Binding PrimaryLabel}"
                                               Classes="commentFieldLabel" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PrimaryValue}"
                                               Classes="commentFieldValue"
                                               ToolTip.Tip="{Binding PrimaryValue}" />
                                </Grid>

                                <Grid ColumnDefinitions="92,*"
                                      ColumnSpacing="12"
                                      IsVisible="{Binding ShowSecondaryInfo}">
                                    <TextBlock Text="{Binding SecondaryLabel}"
                                               Classes="commentFieldLabel" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SecondaryValue}"
                                               Classes="commentFieldValue"
                                               ToolTip.Tip="{Binding SecondaryValue}" />
                                </Grid>

                                <Grid ColumnDefinitions="92,*"
                                      ColumnSpacing="12">
                                    <TextBlock Text="当前备注"
                                               Classes="commentFieldLabel" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding OriginalCommentDisplay}"
                                               Classes="commentFieldValue"
                                               ToolTip.Tip="{Binding OriginalCommentDisplay}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Classes="commentErrorBanner"
                                IsVisible="{Binding HasError}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Classes="commentErrorText" />
                        </Border>

                        <Border Grid.Row="2"
                                Classes="commentSection"
                                Padding="16,14">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="10">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">
                                    <TextBlock Text="新备注"
                                               Classes="commentSectionTitle"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Text="留空后保存会清空当前备注"
                                               Classes="commentSectionHint"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="支持直接修改表备注或字段备注，保存后右侧详情会立即刷新。"
                                           Classes="commentSectionHint" />

                                <TextBox Grid.Row="2"
                                         Text="{Binding EditableComment}"
                                         Classes="commentEditorInput"
                                         IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Classes="commentFooter">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock Text="保存后会直接写回数据库元数据。"
                                   Classes="commentFooterTip"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="12">
                            <Button Command="{Binding CancelCommand}"
                                    Classes="secondary commentFooterButton"
                                    Content="取消" />
                            <Button Command="{Binding SaveCommand}"
                                    Classes="modern commentFooterButton"
                                    Content="保存" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
