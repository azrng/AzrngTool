<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="AzrngTools.Controls.Database.LoadingOverlay"
             x:CompileBindings="False">

    <Grid x:Name="RootGrid"
          IsVisible="False"
          Background="{DynamicResource Brush.Overlay.Scrim}"
          ZIndex="9999">
        <Border Background="{DynamicResource Brush.Panel.Background}"
                BorderBrush="{DynamicResource Brush.Panel.Stroke}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Display}"
                Padding="32,24"
                BoxShadow="{DynamicResource Shadow.LG}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="200">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border x:Name="SpinnerBorder"
                        Width="40" Height="40"
                        CornerRadius="20"
                        BorderThickness="4"
                        BorderBrush="{DynamicResource Brush.Accent.Strong}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                <TextBlock x:Name="PART_LoadingText"
                           Text="加载中..."
                           HorizontalAlignment="Center"
                           FontWeight="Medium"
                           FontSize="14"
                           Foreground="{DynamicResource Brush.Text.Primary}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
