<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:AzrngTools.Models.Database"
             xmlns:controls="using:AzrngTools.Controls.Database"
             x:Class="AzrngTools.Controls.Database.DatabaseTree"
             x:CompileBindings="False"
             x:DataType="controls:DatabaseTree"
             x:Name="RootControl">

    <Design.DataContext>
        <models:TreeNodeItem Name="Root" DisplayName="数据库对象" />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <TreeView x:Name="DatabaseTreeView"
                  ItemsSource="{Binding #RootControl.FilteredChildren}"
                  MinHeight="200"
                  Background="Transparent"
                  BorderThickness="0">
            <TreeView.DataTemplates>
                <TreeDataTemplate DataType="models:TreeNodeItem" ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="Auto,8,*"
                          Margin="{StaticResource Thickness.0.8}">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding IconGlyph}"
                                   FontSize="{DynamicResource Font.Size.Body}"
                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   FontSize="{DynamicResource Font.Size.Body}"
                                   FontWeight="{DynamicResource Font.Weight.SemiBold}"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </TreeDataTemplate>
            </TreeView.DataTemplates>

            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="Padding" Value="{StaticResource Thickness.10.4}" />
                    <Setter Property="Margin" Value="{StaticResource Thickness.Top.2}" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>

                <Style Selector="TreeViewItem:pointerover">
                    <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}" />
                </Style>

                <Style Selector="TreeViewItem:selected">
                    <Setter Property="Background" Value="{DynamicResource Brush.Nav.SelectedBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                </Style>

                <Style Selector="TreeViewItem > Border">
                    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
                </Style>
            </TreeView.Styles>
        </TreeView>

        <Border IsVisible="{Binding #RootControl.IsLoading}"
                Background="{DynamicResource Brush.Panel.Background}"
                BorderBrush="{DynamicResource Brush.Panel.Stroke}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="{StaticResource Thickness.24}"
                CornerRadius="{StaticResource Radius.XL}">
            <StackPanel Spacing="{StaticResource Space.16}"
                        HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="40"
                             Height="40"
                             HorizontalAlignment="Center" />
                <TextBlock Text="正在加载..."
                           Classes="subheading"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding #RootControl.LoadingText}"
                           Classes="muted"
                           FontSize="{DynamicResource Font.Size.Caption}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource Brush.Panel.Background}"
                BorderBrush="{DynamicResource Brush.Panel.Stroke}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="{StaticResource Thickness.24}"
                CornerRadius="{StaticResource Radius.XL}">
            <Border.IsVisible>
                <MultiBinding Converter="{StaticResource AllTrueConverter}">
                    <Binding Path="#DatabaseTreeView.ItemCount"
                             Converter="{StaticResource EqualToZeroConverter}" />
                    <Binding Path="#RootControl.IsLoading"
                             Converter="{StaticResource InvertedBoolConverter}" />
                </MultiBinding>
            </Border.IsVisible>
            <StackPanel Spacing="{StaticResource Space.12}"
                        HorizontalAlignment="Center">
                <TextBlock Text="DB"
                           FontSize="{StaticResource FontSize.Hero}"
                           FontWeight="{DynamicResource Font.Weight.Bold}"
                           Foreground="{DynamicResource Brush.Accent.Strong}"
                           HorizontalAlignment="Center"
                           Opacity="0.5" />
                <TextBlock Text="暂无数据"
                           Classes="subheading"
                           HorizontalAlignment="Center" />
                <TextBlock Text="当前节点下还没有可展示的对象，切换数据库或稍后刷新后再试。"
                           Classes="caption"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="220" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
