<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="DataGrid.modern">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="RowBackground" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <Style Selector="DataGrid.modern > DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="DataGrid.modern DataGridCell">
        <Setter Property="Padding" Value="{StaticResource Thickness.12}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="DataGrid.modern DataGridRow:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
    </Style>

    <Style Selector="DataGrid.modern DataGridRow:selected">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
    </Style>

    <Style Selector="DataGrid.modern DataGridRow.alternating">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
    </Style>

</Styles>
