<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Miscellaneous Control Styles -->

    <!-- Card Style -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}"/>
        <Setter Property="Padding" Value="{DynamicResource Space.XL}"/>
    </Style>

    <!-- Sidebar Styles -->
    <Style Selector="ListBox.sidebar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBoxItem.sidebarItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="{DynamicResource Space.MD}"/>
        <Setter Property="Margin" Value="{DynamicResource Space.SM}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="ListBoxItem.sidebarItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
    </Style>

    <Style Selector="ListBoxItem.sidebarItem:selected">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.SelectedBackground}"/>
    </Style>

    <Style Selector="ListBoxItem.sidebarItem:selected TextBlock.icon">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
    </Style>

    <Style Selector="ListBoxItem.sidebarItem:selected TextBlock.label">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
    </Style>

    <!-- Tab Control -->
    <Style Selector="TabControl.modern">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="TabControl.modern TabItem">
        <Setter Property="Padding" Value="{DynamicResource Space.MD}"/>
        <Setter Property="Margin" Value="4,0,4,0"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
    </Style>

    <Style Selector="TabControl.modern TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
    </Style>

    <!-- Text Styles -->
    <Style Selector="TextBlock.heading">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.TitleLarge}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="TextBlock.subheading">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodyLarge}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="TextBlock.body">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
    </Style>

    <!-- Icon Styles -->
    <Style Selector="TextBlock.icon">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <!-- Tab Button Styles -->
    <Style Selector="Button.tabButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.MD}"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.tabButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="Button.tabButton:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
    </Style>

    <Style Selector="Button.tabButton.tabActive">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
    </Style>

    <Style Selector="Button.tabButton.tabActive:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
    </Style>

    <!-- Helper Classes -->
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="TextBlock.primary">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
    </Style>

    <!-- Window Control Border Group -->
    <Style Selector="Border.windowControlGroup">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- Window Control Glyph -->
    <Style Selector="TextBlock.windowControlGlyph">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.windowControl.close TextBlock.windowControlGlyph">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="Button.windowControl.close:pointerover TextBlock.windowControlGlyph">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
    </Style>

    <!-- Excel Icon Badge -->
    <Style Selector="Border.excelIconBadge">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Brand.ExcelBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Brand.ExcelBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="TextBlock.excelIconGlyph">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Bold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.toolbarStrip">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="16,10"/>
    </Style>

    <Style Selector="Border.toolbarCommandBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}"/>
        <Setter Property="Padding" Value="14,10"/>
    </Style>

    <Style Selector="Border.toolbarStatCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <Style Selector="Border.browserPanel">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}"/>
    </Style>

    <Style Selector="Border.browserSection">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="20,18"/>
    </Style>

    <Style Selector="Border.browserCompactSection">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="18,16,18,14"/>
    </Style>

    <Style Selector="Border.browserTreeSurface">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="ScrollViewer.browserTreeScroll">
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.workspaceSurface">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="Border.overviewHeroCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}"/>
        <Setter Property="Padding" Value="22"/>
    </Style>

    <Style Selector="Border.overviewHeroPill">
        <Setter Property="Background" Value="{DynamicResource Brush.Hero.GlassBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Hero.GlassBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>

    <Style Selector="TextBlock.overviewHeroPillText">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Opacity" Value="0.96"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.overviewMetricCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style Selector="Border.overviewQuickCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style Selector="Border.overviewIconTile">
        <Setter Property="Width" Value="150"/>
        <Setter Property="Height" Value="150"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Hero.TileBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Hero.TileBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.metricIconBadge">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Info.50}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Info.100}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.statusPill">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Padding" Value="10,5"/>
    </Style>

    <Style Selector="TextBlock.statusPillText">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.metricValue">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="TextBlock.metricLabel">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="ScrollViewer.schemaWorkspaceScroll">
        <Setter Property="Padding" Value="20,18,20,20"/>
    </Style>

    <Style Selector="TextBlock.schemaWorkspaceTitle">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.TitleLarge}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="TextBlock.schemaWorkspaceSubtitle">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="Border.schemaMetricCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.LG}"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="MinHeight" Value="78"/>
    </Style>

    <Style Selector="TextBlock.schemaMetricLabel">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="TextBlock.schemaMetricValue">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodyLarge}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="TextBlock.schemaMetricValue.prominent">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Title}"/>
    </Style>

    <Style Selector="Border.detailGridShell">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.detailGridHeader">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="Border.detailGridRow">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="Border.dbWorkbenchIdentityBadge">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchIdentityText">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Title.Sm}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Bold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.dbWorkbenchHeroCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Hero}"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <Style Selector="Border.dbWorkbenchHeroBadge">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchHeroBadgeText">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchHeroTitle">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Hero}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
    </Style>

    <Style Selector="Border.dbWorkbenchInfoCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchInfoValue">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodyLarge}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
    </Style>

    <Style Selector="Border.dbWorkbenchStatusCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Display}"/>
        <Setter Property="Padding" Value="18"/>
    </Style>

    <Style Selector="Border.dbWorkbenchStatePill">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Padding" Value="10,5"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchStatePillText">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
    </Style>

    <Style Selector="Border.dbWorkbenchMiniMetricCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="MinHeight" Value="74"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchMiniMetricLabel">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchMiniMetricValue">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Title.Md}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
    </Style>

    <Style Selector="Border.dbWorkbenchSectionCard">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="18"/>
    </Style>

    <Style Selector="Border.dbWorkbenchSectionCard.subtle">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
    </Style>

    <Style Selector="Border.dbWorkbenchStepRow">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <Style Selector="Border.dbWorkbenchStepBadge">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchStepBadgeText">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.dbWorkbenchStateRow">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <Style Selector="TextBlock.dbWorkbenchStateValue">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.detailGridHeaderText">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.detailGridCell">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.detailGridCell.primary">
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
    </Style>

    <Style Selector="TextBlock.detailGridCell.secondary">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="TextBlock.detailGridCell.mono">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Monospace}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
    </Style>

    <Style Selector="TextBlock.detailGridCell.center">
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.booleanBadge">
        <Setter Property="MinWidth" Value="34"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.booleanBadge.positive">
        <Setter Property="Background" Value="{DynamicResource Brush.Success.50}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Success.100}"/>
    </Style>

    <Style Selector="Border.booleanBadge.negative">
        <Setter Property="Background" Value="{DynamicResource Brush.Error.50}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error.100}"/>
    </Style>

    <Style Selector="TextBlock.booleanBadgeText">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.booleanBadgeText.positive">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Success.Text}"/>
    </Style>

    <Style Selector="TextBlock.booleanBadgeText.negative">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error.Text}"/>
    </Style>

</Styles>
