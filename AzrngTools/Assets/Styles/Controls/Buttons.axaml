<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Button Styles -->
    <!-- Based on design-system.yaml component rules -->

    <!-- Modern Button (Primary) -->
    <Style Selector="Button.modern">
        <Setter Property="Background" Value="{DynamicResource Brush.Brand.500}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Neutral.0}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{DynamicResource Space.LG}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.modern:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Brand.600}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Neutral.0}"/>
    </Style>

    <Style Selector="Button.modern:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Brand.700}"/>
    </Style>

    <!-- Secondary Button -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.0}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{DynamicResource Space.LG}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.50}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Brand.500}"/>
    </Style>

    <!-- Accent Button -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
        <Setter Property="Foreground" Value="#2C3E50"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{DynamicResource Space.LG}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="#45D1B3"/>
    </Style>

    <!-- Icon Button -->
    <Style Selector="Button.iconButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{DynamicResource Space.SM}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.iconButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Info.50}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Brand.500}"/>
    </Style>

    <!-- Default Button -->
    <Style Selector="Button.defaultButton">
        <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Neutral.0}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{DynamicResource Space.MD}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.defaultButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource PrimaryHover}"/>
    </Style>

    <!-- Window Control Buttons -->
    <Style Selector="Button.windowControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.windowControl:pointerover">
        <Setter Property="Background" Value="#EEF3FA"/>
    </Style>

    <Style Selector="Button.windowControl:pressed">
        <Setter Property="Background" Value="#E3EBF6"/>
    </Style>

    <Style Selector="Button.windowControl.close:pointerover">
        <Setter Property="Background" Value="#E14D5C"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Neutral.0}"/>
    </Style>

    <Style Selector="Button.windowControl.close:pressed">
        <Setter Property="Background" Value="#C83D4B"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Neutral.0}"/>
    </Style>

    <!-- Excel Export Button -->
    <Style Selector="Button.excelExportButton">
        <Setter Property="Background" Value="#F7FBF7"/>
        <Setter Property="Foreground" Value="#245A31"/>
        <Setter Property="BorderBrush" Value="#CFE3D4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.excelExportButton:pointerover">
        <Setter Property="Background" Value="#EEF8EF"/>
        <Setter Property="BorderBrush" Value="#9FCAA8"/>
        <Setter Property="Foreground" Value="#1E4E2A"/>
    </Style>

    <Style Selector="Button.excelExportButton:pressed">
        <Setter Property="Background" Value="#E6F3E8"/>
        <Setter Property="BorderBrush" Value="#8BB996"/>
    </Style>

    <Style Selector="Button.toolbarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.toolbarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Info.50}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Info.100}"/>
    </Style>

    <Style Selector="Button.toolbarAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Info.100}"/>
    </Style>

    <Style Selector="Button.sidebarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.sidebarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.0}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Brand.300}"/>
    </Style>

    <Style Selector="Button.sidebarAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.100}"/>
    </Style>

    <Style Selector="Button.overviewAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.0}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Brand.700}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.overviewAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.50}"/>
    </Style>

    <Style Selector="Button.overviewAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Neutral.100}"/>
    </Style>

    <Style Selector="Button.inlineAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Info.50}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Info.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Info.100}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.inlineAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Info.100}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Brand.300}"/>
    </Style>

    <Style Selector="Button.inlineAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Info.100}"/>
    </Style>

    <Style Selector="Button.workbenchToolbarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.workbenchToolbarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.workbenchToolbarAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style Selector="Button.workbenchAccentAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.14.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.workbenchAccentAction:pointerover">
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.workbenchAccentAction:pressed">
        <Setter Property="Opacity" Value="0.84"/>
    </Style>

    <Style Selector="Button.workbenchSidebarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.10.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.workbenchSidebarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.workbenchSidebarAction:pressed">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

</Styles>
