<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.modern">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.14.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.modern:pointerover">
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.modern:pressed">
        <Setter Property="Opacity" Value="0.84"/>
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.14.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.14.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}"/>
    </Style>

    <Style Selector="Button.iconButton">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.10.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.iconButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.defaultButton">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.defaultButton:pointerover">
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.windowControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.windowControl:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
    </Style>

    <Style Selector="Button.windowControl:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.windowControl.close:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Border.Danger}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
    </Style>

    <Style Selector="Button.windowControl.close:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Border.Danger}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="Opacity" Value="0.84"/>
    </Style>

    <Style Selector="Button.excelExportButton">
        <Setter Property="Background" Value="{DynamicResource Brush.Status.Success.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Success.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12.4}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.excelExportButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Success.Text}"/>
    </Style>

    <Style Selector="Button.excelExportButton:pressed">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style Selector="Button.toolbarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.toolbarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.toolbarAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.sidebarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.10.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.sidebarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.sidebarAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
    </Style>

    <Style Selector="Button.overviewAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.overviewAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.overviewAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
    </Style>

    <Style Selector="Button.inlineAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.10.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.inlineAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.inlineAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.workbenchToolbarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.12.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.workbenchToolbarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.workbenchToolbarAction:pressed">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style Selector="Button.workbenchAccentAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.14.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.workbenchAccentAction:pointerover">
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.workbenchAccentAction:pressed">
        <Setter Property="Opacity" Value="0.84"/>
    </Style>

    <Style Selector="Button.workbenchSidebarAction">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}"/>
        <Setter Property="Padding" Value="{StaticResource Thickness.10.4}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}"/>
        <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <Style Selector="Button.workbenchSidebarAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}"/>
    </Style>

    <Style Selector="Button.workbenchSidebarAction:pressed">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

</Styles>
