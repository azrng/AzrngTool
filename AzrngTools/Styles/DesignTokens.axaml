    <Thickness x:Key="Thickness.Right.16">0,0,16,0</Thickness>
    <Thickness x:Key="Thickness.Right.30">0,0,30,0</Thickness>
    <Thickness x:Key="Thickness.10.0.10.10">10,0,10,10</Thickness>
