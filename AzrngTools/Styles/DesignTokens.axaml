    <Thickness x:Key="Thickness.0.10">0,10</Thickness>
    <Thickness x:Key="Thickness.0.20">0,20</Thickness>
    <Thickness x:Key="Thickness.5.0">5,0</Thickness>
    <Thickness x:Key="Thickness.10.0">10,0</Thickness>
    <Thickness x:Key="Thickness.20.0">20,0</Thickness>
    <Thickness x:Key="Thickness.Top.2">0,2,0,0</Thickness>
    <Thickness x:Key="Thickness.Top.5">0,5,0,0</Thickness>
    <Thickness x:Key="Thickness.Top.8">0,8,0,0</Thickness>
    <Thickness x:Key="Thickness.Top.10">0,10,0,0</Thickness>
