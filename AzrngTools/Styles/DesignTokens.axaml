    <CornerRadius x:Key="Radius.Xs">3</CornerRadius>
    <CornerRadius x:Key="Radius.Sm">5</CornerRadius>
    <CornerRadius x:Key="Radius.Md">6</CornerRadius>
    <CornerRadius x:Key="Radius.Lg">8</CornerRadius>
    <CornerRadius x:Key="Radius.Xl">10</CornerRadius>
    <CornerRadius x:Key="Radius.Xxl">15</CornerRadius>
    <CornerRadius x:Key="Radius.Display">18</CornerRadius>
    <CornerRadius x:Key="Radius.Hero">20</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">999</CornerRadius>

    <FontFamily x:Key="FontFamily.App">avares://Avalonia.Fonts.Inter#Inter</FontFamily>

    <SolidColorBrush x:Key="Brush.Border.Muted">#FFAAAAAA</SolidColorBrush>
    <SolidColorBrush x:Key="Brush.Border.Divider">#22000000</SolidColorBrush>
    <SolidColorBrush x:Key="Brush.Text.OnAccent">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="Brush.Surface.Transparent">Transparent</SolidColorBrush>
</ResourceDictionary>
