<Window
    ExtendClientAreaToDecorationsHint="True"
    Icon="/Assets/logo.ico"
    Height="{StaticResource Layout.MainWindow.Height}"
    Width="{StaticResource Layout.MainWindow.Width}"
    WindowDecorations="None"
    Title="AzrngTools"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    x:Name="RootWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzrngTools.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="../Themes/TabMenu.axaml" />
                <ResourceInclude Source="../Themes/ToggleButton.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Panel>
        <Grid Margin="{StaticResource Thickness.12}" RowDefinitions="Auto,*" RowSpacing="{StaticResource Space.12}">
            <Border
                Grid.Row="0"
                Classes="shell-panel"
                DoubleTapped="HeaderBorder_OnDoubleTapped"
                Name="HeaderBorder"
                PointerPressed="HeaderBorder_OnPointerPressed">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}" VerticalAlignment="Center">
                        <TextBlock Classes="app-title" Text="{Binding AppTitle}" />
                        <TextBlock Classes="app-subtitle" Text="{Binding AppSubtitle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="{StaticResource Space.8}" VerticalAlignment="Center">
                        <TextBlock
                            Classes="app-subtitle"
                            Text="放下个人素质，享受缺德人生"
                            VerticalAlignment="Center" />

                        <ToggleSwitch
                            Command="{Binding ToggleCheckedChangedCommand}"
                            IsChecked="{Binding IsDarkThemeEnabled, Mode=TwoWay}"
                            Padding="{StaticResource Thickness.4}"
                            Theme="{DynamicResource ButtonToggleSwitch}">
                            <ToggleSwitch.OnContent>
                                <PathIcon
                                    Data="M12 23C18.0751 23 23 18.0751 23 12C23 5.92487 18.0751 1 12 1C5.92487 1 1 5.92487 1 12C1 18.0751 5.92487 23 12 23ZM17 15C17.476 15 17.9408 14.9525 18.3901 14.862C17.296 17.3011 14.8464 19 12 19C8.13401 19 5 15.866 5 12C5 8.60996 7.40983 5.78277 10.6099 5.13803C10.218 6.01173 10 6.98041 10 8C10 11.866 13.134 15 17 15Z"
                                    Foreground="{DynamicResource ButtonDefaultTertiaryForeground}"
                                    Height="{StaticResource Layout.Icon.Sm}"
                                    Width="{StaticResource Layout.Icon.Sm}" />
                            </ToggleSwitch.OnContent>
                            <ToggleSwitch.OffContent>
                                <PathIcon
                                    Data="M3.55 19.09L4.96 20.5L6.76 18.71L5.34 17.29M12 6C8.69 6 6 8.69 6 12S8.69 18 12 18 18 15.31 18 12C18 8.68 15.31 6 12 6M20 13H23V11H20M17.24 18.71L19.04 20.5L20.45 19.09L18.66 17.29M20.45 5L19.04 3.6L17.24 5.39L18.66 6.81M13 1H11V4H13M6.76 5.39L4.96 3.6L3.55 5L5.34 6.81L6.76 5.39M1 13H4V11H1M13 20H11V23H13"
                                    Foreground="{DynamicResource ButtonDefaultTertiaryForeground}"
                                    Height="{StaticResource Layout.Icon.Sm}"
                                    Width="{StaticResource Layout.Icon.Sm}" />
                            </ToggleSwitch.OffContent>
                        </ToggleSwitch>

                        <Button
                            Classes="Tertiary"
                            Click="BtnMin_OnClick"
                            Content="―"
                            Theme="{DynamicResource BorderlessButton}"
                            x:Name="btnMin" />
                        <Button
                            Classes="Danger"
                            Click="BtnClose_OnClick"
                            Content="✕"
                            Theme="{DynamicResource BorderlessButton}"
                            x:Name="btnClose" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="{StaticResource Space.12}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource Layout.Shell.SidebarWidth}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Classes="shell-sidebar">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="{StaticResource Space.12}">
                        <TextBox
                            Grid.Row="0"
                            Text="{Binding SearchKeyword}"
                            PlaceholderText="搜索工具 / 分组..." />

                        <Border
                            Grid.Row="1"
                            Classes="tool-card-soft sidebar-stats">
                            <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="{StaticResource Space.10}">
                                <Button
                                    Grid.Column="0"
                                    Classes="Tertiary"
                                    Command="{Binding GoHomeCommand}"
                                    Padding="{StaticResource Thickness.12}"
                                    Theme="{DynamicResource BorderlessButton}"
                                    ToolTip.Tip="首页">
                                    <PathIcon
                                        Data="M10 20V14H14V20H19V12H22L12 3L2 12H5V20H10Z"
                                        Foreground="{DynamicResource Brush.Accent.Strong}"
                                        Height="{StaticResource Layout.Icon.Sm}"
                                        Width="{StaticResource Layout.Icon.Sm}" />
                                </Button>
                                <StackPanel Grid.Column="1" Spacing="{StaticResource Space.2}">
                                    <TextBlock Classes="metric-label" Text="总工具" />
                                    <TextBlock Classes="metric-value compact" Text="{Binding TotalToolCount}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="{StaticResource Space.2}">
                                    <TextBlock Classes="metric-label" Text="分类" />
                                    <TextBlock Classes="metric-value compact" Text="{Binding CategoryCount}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock
                            Grid.Row="2"
                            Classes="sidebar-section-caption"
                            Text="常用入口" />

                        <ListBox
                            Grid.Row="3"
                            Classes="shell-nav"
                            ItemsSource="{Binding RootMenuItems}"
                            SelectedItem="{Binding SelectedListItem, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Classes="nav-item-text" Text="{Binding Title}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock
                            Grid.Row="4"
                            Classes="sidebar-section-caption"
                            Text="{Binding SearchSummary}" />

                        <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GroupMenuItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                            <Expander.Header>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.8}">
                                                    <TextBlock Classes="nav-group-title" Text="{Binding Title}" />
                                                    <Border Grid.Column="1" Classes="badge-pill compact">
                                                        <TextBlock Classes="badge-text" Text="{Binding Child.Count}" />
                                                    </Border>
                                                </Grid>
                                            </Expander.Header>
                                            <ListBox
                                                Classes="shell-nav"
                                                ItemsSource="{Binding Child}"
                                                SelectedItem="{ReflectionBinding #RootWindow.DataContext.SelectedListItem, Mode=TwoWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Classes="nav-item-text" Text="{Binding Title}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Border Classes="shell-panel">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid HorizontalAlignment="Stretch"
                                  MinWidth="0">
                                <TransitioningContentControl Content="{Binding CurrentPage}"
                                                             HorizontalAlignment="Stretch" />
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Panel IsHitTestVisible="False"
               ZIndex="9999">
            <StackPanel x:Name="GlobalToastContainer"
                        Margin="{StaticResource Thickness.20}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Spacing="{StaticResource Space.8}" />
        </Panel>
    </Panel>
</Window>
