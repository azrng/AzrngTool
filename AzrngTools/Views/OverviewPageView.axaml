<UserControl
    x:Class="AzrngTools.Views.OverviewPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:AzrngTools.ViewModels"
    d:DesignHeight="760"
    d:DesignWidth="1100"
    x:DataType="vm:OverviewPageViewModel"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="dashboard-hero">
                <StackPanel Spacing="{StaticResource Space.10}">
                    <TextBlock Classes="hero-eyebrow" Text="AzrngTools 开发工具集" />
                    <TextBlock Classes="hero-title" Text="覆盖数据库、接口调试、生成加密、编码解码与格式化的日常开发工作台" />

                    <WrapPanel Classes="tool-actions">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text=".NET 10" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="Avalonia 12" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="数据库 / 接口 / 文本" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="dashboard-stat">
                    <StackPanel Spacing="{StaticResource Space.6}">
                        <TextBlock Classes="stat-value" Text="33" />
                        <TextBlock Classes="stat-label" Text="可用工具入口" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="dashboard-stat">
                    <StackPanel Spacing="{StaticResource Space.6}">
                        <TextBlock Classes="stat-value" Text="7" />
                        <TextBlock Classes="stat-label" Text="功能分组" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="dashboard-stat">
                    <StackPanel Spacing="{StaticResource Space.6}">
                        <TextBlock Classes="stat-value" Text="Light / Dark" />
                        <TextBlock Classes="stat-label" Text="亮暗主题" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <StackPanel Spacing="{StaticResource Space.12}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="当前能力范围" />
                            <TextBlock Classes="section-copy" Text="左侧导航按场景组织工具，适合在开发、调试、数据查看和文本处理之间快速切换。" />
                        </StackPanel>

                        <Border Classes="dashboard-note">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="metric-label" Text="1. 数据库与接口" />
                                <TextBlock Classes="section-copy" Text="数据库工作台支持连接浏览、对象详情、查询预览与文档导出；接口调试用于快速组织请求并查看响应。" />
                            </StackPanel>
                        </Border>

                        <Border Classes="dashboard-note">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="metric-label" Text="2. 编码、生成与加密" />
                                <TextBlock Classes="section-copy" Text="内置 GUID、密码、JSON Schema、AES、DES、SM4、RSA、Hash、Base64、URL、JWT、Gzip 等常用处理入口。" />
                            </StackPanel>
                        </Border>

                        <Border Classes="dashboard-note">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="metric-label" Text="3. 格式化与辅助" />
                                <TextBlock Classes="section-copy" Text="提供 JSON、SQL、XML、正则、字数统计、人民币大写、时间戳、翻译、硬件信息和关于更新等辅助能力。" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
