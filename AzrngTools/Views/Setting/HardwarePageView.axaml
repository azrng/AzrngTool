<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Setting.HardwarePageView"
    x:DataType="vm:HardwarePageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:AzrngTools.ViewModels.Setting"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="硬件信息概览" />
                        <TextBlock Classes="section-copy" Text="集中展示当前设备的指纹、CPU、BIOS、MAC 和硬盘信息。" />
                    </StackPanel>

                    <Border Grid.Column="1" Classes="badge-pill" VerticalAlignment="Center">
                        <TextBlock Classes="badge-text" Text="本机信息" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="{StaticResource Space.12}" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
                <Border Grid.Row="0" Grid.Column="0" Classes="tool-card-roomy">
                    <StackPanel Spacing="{StaticResource Space.8}">
                        <TextBlock Classes="metric-label" Text="设备指纹" />
                        <TextBox
                            Classes="Standard flat-readonly"
                            IsReadOnly="True"
                            Text="{Binding Fingerprint}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Classes="tool-card-roomy">
                    <StackPanel Spacing="{StaticResource Space.8}">
                        <TextBlock Classes="metric-label" Text="CPU 信息" />
                        <TextBox
                            Classes="Standard flat-readonly"
                            IsReadOnly="True"
                            Text="{Binding CpuId}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Classes="tool-card-roomy">
                    <StackPanel Spacing="{StaticResource Space.8}">
                        <TextBlock Classes="metric-label" Text="BIOS 序列号" />
                        <TextBox
                            Classes="Standard flat-readonly"
                            IsReadOnly="True"
                            Text="{Binding BiosSerial}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Classes="tool-card-roomy">
                    <StackPanel Spacing="{StaticResource Space.8}">
                        <TextBlock Classes="metric-label" Text="MAC 地址" />
                        <TextBox
                            Classes="Standard flat-readonly"
                            IsReadOnly="True"
                            Text="{Binding MacAddress}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="tool-card-roomy">
                    <StackPanel Spacing="{StaticResource Space.8}">
                        <TextBlock Classes="metric-label" Text="硬盘序列号" />
                        <TextBox
                            Classes="Standard flat-readonly"
                            IsReadOnly="True"
                            Text="{Binding HardDiskId}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
