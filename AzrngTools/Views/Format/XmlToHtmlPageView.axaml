<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Format.XmlToHtmlPageView"
    x:DataType="format:XmlToHtmlPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:format="clr-namespace:AzrngTools.ViewModels.Format"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="XML 转 HTML 工作台" />
                        <TextBlock Classes="section-copy" Text="继续使用现有 XML 与 XSLT 转换逻辑，把输入、执行和输出整理成更明确的三个区域，减少旧页面的拥挤感。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="XML" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="XSLT" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="HTML" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="XML 输入" />
                            <TextBlock Classes="section-copy" Text="输入待转换的 XML 内容，执行时会与右侧 XSLT 一起参与转换。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="240"
                            Text="{Binding XmlContent}"
                            PlaceholderText="请输入 XML 内容" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="XSLT 输入" />
                            <TextBlock Classes="section-copy" Text="输入用于转换的 XSLT 模板；如果模板为空，仍由原有消息提示引导用户补全。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="240"
                            Text="{Binding XsltContent}"
                            PlaceholderText="请输入 XSLT 内容" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="0.95*,1.05*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="执行转换" />
                            <TextBlock Classes="section-copy" Text="保留单一“转换 XML”动作，不引入新的处理流程；转换结果会显示在右侧输出区。" />
                        </StackPanel>

                        <WrapPanel Grid.Row="1" Classes="tool-actions">
                            <Button
                                Command="{Binding HandleCommand}"
                                Content="转换 XML"
                                Theme="{DynamicResource SolidButton}" />
                        </WrapPanel>

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="metric-label" Text="使用提示" />
                                <TextBlock Classes="Small" Text="• XML 和 XSLT 两个输入区都不能为空，空值校验继续复用现有提示逻辑。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="• 输出区展示转换后的 HTML 文本，方便进一步复制或检查。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="HTML 输出" />
                            <TextBlock Classes="section-copy" Text="转换成功后会在这里显示 HTML 内容，保留只读展示模式，避免误把结果区当作输入区。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="260"
                            IsReadOnly="True"
                            Text="{Binding HtmlContent}"
                            PlaceholderText="HTML 内容" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
