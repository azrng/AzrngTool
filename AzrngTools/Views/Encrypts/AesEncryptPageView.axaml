<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encrypts.AesEncryptPageView"
    x:DataType="vm:AesEncryptPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzrngTools.ViewModels.Encrypts"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="AES 加解密工作台" />
                        <TextBlock Classes="section-copy" Text="支持 AES 加密解密，并可组合密钥、IV、模式和填充方式进行验证。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="AES" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="模式 / 填充" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="Base64 / Hex" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.2*,0.8*" ColumnSpacing="{StaticResource Space.12}">
                <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <Border Grid.Row="0" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="输入内容" />
                                <TextBlock Classes="section-copy" Text="输入待加密或待解密的文本，处理动作会根据右侧参数设置直接生成结果。" />
                            </StackPanel>

                            <TextBox
                                Grid.Row="1"
                                AcceptsReturn="True"
                                Classes="Standard"
                                Height="220"
                                Text="{Binding Original}"
                                Watermark="请输入要加密或解密的内容" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="{StaticResource Space.12}">
                        <Border Grid.Column="0" Classes="tool-card-roomy">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="section-title" Text="密钥" />
                                    <TextBlock Classes="section-copy" Text="密钥格式由右侧“密钥 / IV 格式”下拉框决定。" />
                                </StackPanel>

                                <TextBox
                                    Grid.Row="1"
                                    Classes="Standard"
                                    Text="{Binding Secret}"
                                    Watermark="请输入密钥" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Classes="tool-card-roomy">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="section-title" Text="IV" />
                                    <TextBlock Classes="section-copy" Text="ECB 模式可留空，其它模式按当前格式输入 IV。" />
                                </StackPanel>

                                <TextBox
                                    Grid.Row="1"
                                    Classes="Standard"
                                    Text="{Binding Iv}"
                                    Watermark="ECB 模式可留空，其它模式请输入 IV" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="处理结果" />
                                <TextBlock Classes="section-copy" Text="结果区保持只读显示，便于和原文对照以及后续复制使用。" />
                            </StackPanel>

                            <TextBox
                                Grid.Row="1"
                                AcceptsReturn="True"
                                Classes="Standard"
                                Height="220"
                                IsReadOnly="True"
                                Text="{Binding Ciphertext}"
                                Watermark="加密或解密后的内容将显示在这里" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="1" Classes="tool-card-roomy" VerticalAlignment="Top">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="参数设置" />
                            <TextBlock Classes="section-copy" Text="输入格式、输出格式、模式与填充方式都继续沿用原有绑定，不改变底层行为。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" Text="输入内容格式" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" SelectedIndex="{Binding InputOriginalTypeIndex}">
                                    <ComboBoxItem Content="Text" />
                                    <ComboBoxItem Content="Base64" />
                                    <ComboBoxItem Content="Hex" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" Text="输出结果格式" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" SelectedIndex="{Binding OutTypeIndex}">
                                    <ComboBoxItem Content="Base64" />
                                    <ComboBoxItem Content="Hex" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" Text="密钥 / IV 格式" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" SelectedIndex="{Binding SecretTypeIndex}">
                                    <ComboBoxItem Content="Text" />
                                    <ComboBoxItem Content="Base64" />
                                    <ComboBoxItem Content="Hex(十六进制)" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" Text="密码模式" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" SelectedIndex="{Binding CipherModeIndex}">
                                    <ComboBoxItem Content="请选择" />
                                    <ComboBoxItem Content="CBC(密码块链)" />
                                    <ComboBoxItem Content="ECB(电子密码本)" />
                                    <ComboBoxItem Content="OFB(输出反馈)" />
                                    <ComboBoxItem Content="CFB(密码反馈)" />
                                    <ComboBoxItem Content="CTS(密码文本窃用)" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" Text="填充模式" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" SelectedIndex="{Binding PaddingModeIndex}">
                                    <ComboBoxItem Content="请选择" />
                                    <ComboBoxItem Content="None" />
                                    <ComboBoxItem Content="PKCS7" />
                                    <ComboBoxItem Content="Zeros" />
                                    <ComboBoxItem Content="ANSIX923" />
                                    <ComboBoxItem Content="ISO10126" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <WrapPanel Grid.Row="6" Classes="tool-actions">
                            <Button Command="{Binding HandlerCommand}" CommandParameter="true" Content="加密" Theme="{DynamicResource SolidButton}" />
                            <Button Command="{Binding HandlerCommand}" CommandParameter="false" Content="解密" Theme="{DynamicResource OutlineButton}" />
                            <Button Command="{Binding ResetCommand}" Content="清空" Theme="{DynamicResource OutlineButton}" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
