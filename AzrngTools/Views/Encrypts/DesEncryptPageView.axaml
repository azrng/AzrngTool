<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encrypts.DesEncryptPageView"
    x:DataType="vm:DesEncryptPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzrngTools.ViewModels.Encrypts"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="DES 加解密工作台" />
                        <TextBlock Classes="section-copy" Text="用于快速验证 DES 加密与解密结果，适合同一段文本反复调整密钥并比对输出。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="DES" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="加密 / 解密" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.0*,1.15*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="输入内容" />
                            <TextBlock Classes="section-copy" Text="输入待加密或待解密的文本，处理动作会直接基于这里的内容执行。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="260"
                            Text="{Binding Original}"
                            PlaceholderText="请输入要处理的文本" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <Border Grid.Row="0" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="密钥与结果" />
                                <TextBlock Classes="section-copy" Text="在同一区域维护密钥和结果，方便修改后立即重新验证。" />
                            </StackPanel>

                            <TextBox
                                Grid.Row="1"
                                Classes="Standard"
                                Text="{Binding Secret}"
                                PlaceholderText="请输入密钥" />

                            <TextBox
                                Grid.Row="2"
                                AcceptsReturn="True"
                                Classes="Standard"
                                Height="220"
                                IsReadOnly="True"
                                Text="{Binding Ciphertext}"
                                PlaceholderText="处理后的内容将显示在这里" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Classes="tool-card-roomy" VerticalAlignment="Top">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="快捷操作" />
                            </StackPanel>

                            <WrapPanel Grid.Row="1" Classes="tool-actions">
                                <Button
                                    Command="{Binding HandlerCommand}"
                                    CommandParameter="true"
                                    Content="DES 加密"
                                    Theme="{DynamicResource SolidButton}" />
                                <Button
                                    Command="{Binding HandlerCommand}"
                                    CommandParameter="false"
                                    Content="DES 解密"
                                    Theme="{DynamicResource OutlineButton}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
