<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encrypts.HmacHashPageView"
    x:DataType="vm:HmacHashPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:AzrngTools.Utils"
    xmlns:vm="using:AzrngTools.ViewModels.Encrypts"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="HMAC Hash 工作台" />
                        <TextBlock Classes="section-copy" Text="支持多种 HMAC 算法，方便结合密钥快速计算摘要结果。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="HMAC MD5" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="HMAC SHA" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.1*,1.0*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="原始内容" />
                            <TextBlock Classes="section-copy" Text="输入待进行 HMAC 计算的文本内容，不同算法按钮都会基于这里的内容执行。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            MinHeight="420"
                            Text="{Binding Original}"
                            PlaceholderText="请输入要进行哈希的内容" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <Border Grid.Row="0" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="密钥与结果" />
                                <TextBlock Classes="section-copy" Text="密钥输入和结果展示拆开排列，便于调整密钥后反复校验不同算法输出。" />
                            </StackPanel>

                            <TextBox
                                Grid.Row="1"
                                Classes="Standard"
                                Text="{Binding Secret}"
                                PlaceholderText="请输入密钥" />

                            <TextBox
                                Grid.Row="2"
                                AcceptsReturn="True"
                                Classes="Standard"
                                MinHeight="300"
                                IsReadOnly="True"
                                Text="{Binding Ciphertext}"
                                PlaceholderText="哈希后的内容" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="算法与格式" />
                                <TextBlock Classes="section-copy" Text="支持切换输出格式和多种 HMAC 算法，便于快速校验摘要结果。" />
                            </StackPanel>

                            <Border Grid.Row="1" Classes="tool-card-soft">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                    <TextBlock Classes="metric-label" Text="输出类型" VerticalAlignment="Center" />
                                    <ComboBox
                                        Grid.Column="1"
                                        ItemsSource="{Binding Source={x:Static utils:EnumValuesHelper.OutTypeValues}}"
                                        SelectedIndex="{Binding OutTypeValue}" />
                                </Grid>
                            </Border>

                            <WrapPanel Grid.Row="2" Classes="tool-actions">
                                <Button Command="{Binding HandlerCommand}" CommandParameter="0" Content="HMAC MD5" Theme="{DynamicResource SolidButton}" />
                                <Button Command="{Binding HandlerCommand}" CommandParameter="1" Content="HMAC SHA1" Theme="{DynamicResource OutlineButton}" />
                                <Button Command="{Binding HandlerCommand}" CommandParameter="2" Content="HMAC SHA256" Theme="{DynamicResource OutlineButton}" />
                                <Button Command="{Binding HandlerCommand}" CommandParameter="3" Content="HMAC SHA512" Theme="{DynamicResource OutlineButton}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
