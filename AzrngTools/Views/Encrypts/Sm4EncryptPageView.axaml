<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encrypts.Sm4EncryptPageView"
    x:DataType="vm:Sm4EncryptPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:AzrngTools.Utils"
    xmlns:vm="using:AzrngTools.ViewModels.Encrypts"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="SM4 加解密工作台" />
                        <TextBlock Classes="section-copy" Text="支持 SM4 加密解密，并可按不同内容格式查看处理结果。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="SM4" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="Base64 / Hex" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.05*,1.0*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="输入内容" />
                            <TextBlock Classes="section-copy" Text="输入待加密或待解密的内容，输出格式选择会决定结果与解密输入的解释方式。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            MinHeight="420"
                            Text="{Binding Original}"
                            PlaceholderText="请输入要加密或解密的内容" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="密钥、结果与格式" />
                            <TextBlock Classes="section-copy" Text="把密钥、格式选择和操作按钮都集中到右侧主工作区，避免下方出现割裂的小卡片。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            Classes="Standard"
                            Text="{Binding Secret}"
                            PlaceholderText="请输入密钥" />

                        <TextBox
                            Grid.Row="2"
                            AcceptsReturn="True"
                            Classes="Standard"
                            MinHeight="280"
                            IsReadOnly="True"
                            Text="{Binding Ciphertext}"
                            PlaceholderText="处理后的内容将显示在这里" />

                        <Border Grid.Row="3" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" Text="内容类型" VerticalAlignment="Center" />
                                <ComboBox
                                    Grid.Column="1"
                                    ItemsSource="{Binding Source={x:Static utils:EnumValuesHelper.OutTypeValues}}"
                                    SelectedIndex="{Binding OutTypeValue}" />
                            </Grid>
                        </Border>

                        <WrapPanel Grid.Row="4" Classes="tool-actions" VerticalAlignment="Bottom">
                            <Button
                                Command="{Binding Sm4HandlerCommand}"
                                CommandParameter="true"
                                Content="加密"
                                Theme="{DynamicResource SolidButton}" />
                            <Button
                                Command="{Binding Sm4HandlerCommand}"
                                CommandParameter="false"
                                Content="解密"
                                Theme="{DynamicResource OutlineButton}" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
