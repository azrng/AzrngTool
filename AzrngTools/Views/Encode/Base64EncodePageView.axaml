<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encode.Base64EncodePageView"
    x:DataType="encode:Base64EncodePageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:encode="clr-namespace:AzrngTools.ViewModels.Encode"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        Margin="{StaticResource Thickness.15}"
        MinHeight="0"
        RowDefinitions="Auto,*"
        RowSpacing="{StaticResource Space.12}"
        x:Name="RootGrid">
            <Border Grid.Row="0" Classes="tool-card-roomy" x:Name="HeaderCard">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="Base64 文本工作台" />
                            <TextBlock Classes="section-copy" Text="把输入、结果和状态信息收口到同一块工作区里，适合连续做 Base64 编码、解码、复制和结果回填。" />
                        </StackPanel>

                        <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Classes="badge-pill">
                                <TextBlock Classes="badge-text" Text="编码" />
                            </Border>
                            <Border Classes="badge-pill">
                                <TextBlock Classes="badge-text" Text="解码" />
                            </Border>
                            <Border Classes="badge-pill">
                                <TextBlock Classes="badge-text" Text="回填" />
                            </Border>
                        </WrapPanel>
                    </Grid>

                    <WrapPanel Grid.Row="1" Classes="tool-actions">
                        <Button
                            Command="{Binding Base64HandlerCommand}"
                            CommandParameter="true"
                            Content="Base64 编码"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding Base64HandlerCommand}"
                            CommandParameter="false"
                            Content="Base64 解码"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding PasteFromClipboardCommand}"
                            Content="从剪贴板导入"
                            Theme="{DynamicResource OutlineButton}" />
                        <Button
                            Command="{Binding CopyResultCommand}"
                            Content="复制结果"
                            Theme="{DynamicResource OutlineButton}" />
                        <Button
                            Command="{Binding ClearCommand}"
                            Content="清空"
                            Theme="{DynamicResource OutlineButton}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid
                Grid.Row="1"
                ColumnDefinitions="1*,1*"
                ColumnSpacing="{StaticResource Space.12}"
                MinHeight="0"
                x:Name="WorkspaceGrid">
                <Border Grid.Column="0" Classes="tool-card-roomy" MinHeight="0">
                    <Grid MinHeight="0" RowDefinitions="Auto,*" RowSpacing="{StaticResource Space.10}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="输入内容" />
                                <TextBlock Classes="section-copy" Text="可直接粘贴普通文本，也可粘贴已有的 Base64 字符串；这里始终作为当前工作输入源。" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="{StaticResource Space.6}">
                                <Border Classes="badge-pill compact">
                                    <TextBlock Classes="badge-text" Text="{Binding OriginalCharacterCount, StringFormat='字符 {0}'}" />
                                </Border>
                                <Border Classes="badge-pill compact">
                                    <TextBlock Classes="badge-text" Text="{Binding OriginalByteCount, StringFormat='字节 {0}'}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            MinHeight="0"
                            Text="{Binding Original}"
                            PlaceholderText="请输入要编码或解码的文本 / Base64 内容" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy" MinHeight="0">
                    <Grid MinHeight="0" RowDefinitions="Auto,*,Auto" RowSpacing="{StaticResource Space.10}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="处理结果" />
                                <TextBlock Classes="section-copy" Text="编码或解码后的内容统一输出在这里，便于立即复制、校验，或直接回填到输入区继续处理。" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="{StaticResource Space.6}">
                                <Border Classes="badge-pill compact">
                                    <TextBlock Classes="badge-text" Text="{Binding ResultCharacterCount, StringFormat='字符 {0}'}" />
                                </Border>
                                <Border Classes="badge-pill compact">
                                    <TextBlock Classes="badge-text" Text="{Binding ResultByteCount, StringFormat='字节 {0}'}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            IsReadOnly="True"
                            MinHeight="0"
                            Text="{Binding HandleText}"
                            PlaceholderText="处理后的内容会显示在这里" />

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <Button
                                    Command="{Binding UseResultAsInputCommand}"
                                    Content="结果回填到输入区"
                                    IsEnabled="{Binding HasResult}"
                                    Theme="{DynamicResource OutlineButton}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding CopyResultCommand}"
                                    Content="复制结果"
                                    IsEnabled="{Binding HasResult}"
                                    Theme="{DynamicResource OutlineButton}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Classes="section-copy"
                                    Text="如果输入不是合法 Base64，页面会保留当前结果，并通过通知提示转换失败。"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
</UserControl>
