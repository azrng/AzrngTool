<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encode.Base64EncodePageView"
    x:DataType="encode:Base64EncodePageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:encode="clr-namespace:AzrngTools.ViewModels.Encode"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="Base64 文本工作台" />
                        <TextBlock Classes="section-copy" Text="适合快速在普通文本和 Base64 字符串之间来回转换，输入和结果并排展示，方便直接对照。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="编码" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="解码" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.05*,1.05*,0.9*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="输入内容" />
                            <TextBlock Classes="section-copy" Text="可直接粘贴普通文本，或已经存在的 Base64 字符串。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="260"
                            Text="{Binding Original}"
                            PlaceholderText="请输入要处理的文本" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="处理结果" />
                            <TextBlock Classes="section-copy" Text="编码或解码后的结果会显示在一里，便于立即复制或继续处理。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="260"
                            IsReadOnly="True"
                            Text="{Binding HandleText}"
                            PlaceholderText="处理后的内容" />
                    </Grid>
                </Border>

                <Border Grid.Column="2" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="操作说明" />
                            <TextBlock Classes="section-copy" Text="一一页持持最精简的双向转换模式，只持留现有编码与解码两个动作。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="Small" Text="• Base64编码：把当前文本转换成 Base64 字符串" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="• Base64解码：把当前 Base64 字符串还原成原始文本" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <TextBlock
                                Classes="section-copy"
                                Text="如果输入不是合法 Base64，页面会持持原结果，并通过通知提示转换失败。"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Classes="tool-card-roomy">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="快捷操作" />
                        <TextBlock Classes="section-copy" Text="直接针对左侧输入区执行操作，结果统一输出到中间结果区。"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="1" Classes="tool-actions">
                        <Button
                            Command="{Binding Base64HandlerCommand}"
                            CommandParameter="true"
                            Content="Base64编码"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding Base64HandlerCommand}"
                            CommandParameter="false"
                            Content="Base64解码"
                            Theme="{DynamicResource SolidButton}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
