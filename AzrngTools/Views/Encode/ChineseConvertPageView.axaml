<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encode.ChineseConvertPageView"
    x:DataType="encode:ChineseConvertPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:encode="clr-namespace:AzrngTools.ViewModels.Encode"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="简繁中文转换工作台" />
                        <TextBlock Classes="section-copy" Text="把输入、转换结果和常用操作拆成清晰区域，适合连续校对简体与繁体内容并快速复制结果。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="简体转繁体" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="繁体转简体" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.05*,1.05*,0.9*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="输入内容" />
                            <TextBlock Classes="section-copy" Text="在这里粘贴待转换的中文文本，适合短句、段落和一般说明性内容。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="280"
                            Text="{Binding Original}"
                            Watermark="请输入要转换的文本" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="转换结果" />
                            <TextBlock Classes="section-copy" Text="结果区保持只读展示，便于对照检查后直接复制到当前工作内容中。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="280"
                            IsReadOnly="True"
                            Text="{Binding HandleText}"
                            Watermark="转换后的内容将显示在这里" />
                    </Grid>
                </Border>

                <Border Grid.Column="2" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="使用说明" />
                            <TextBlock Classes="section-copy" Text="保留现有双向转换、复制和清空操作，适合反复对照查看不同写法。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="Small" Text="简体转繁体：将当前输入内容转换为繁体写法。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="繁体转简体：将当前输入内容转换为简体写法。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="复制结果：仅复制右侧结果区内容。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <TextBlock
                                Classes="section-copy"
                                Text="字符级简繁转换适合常见汉字内容，个别词语在上下文语义上可能存在多种对应写法。"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Classes="tool-card-roomy">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="快捷操作" />
                        <TextBlock Classes="section-copy" Text="输入一次即可在两个方向之间切换验证，同时保留复制和清空按钮，方便连续处理多段文本。" />
                    </StackPanel>

                    <WrapPanel Grid.Row="1" Classes="tool-actions">
                        <Button
                            Command="{Binding SimplifiedToTraditionalCommand}"
                            Content="简体转繁体"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding TraditionalToSimplifiedCommand}"
                            Content="繁体转简体"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding CopyResultCommand}"
                            Content="复制结果"
                            Theme="{DynamicResource OutlineButton}" />
                        <Button
                            Command="{Binding ClearCommand}"
                            Content="清空"
                            Theme="{DynamicResource OutlineButton}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
