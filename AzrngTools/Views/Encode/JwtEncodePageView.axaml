<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encode.JwtEncodePageView"
    x:DataType="vm:JwtEncodePageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
    xmlns:behaviors="clr-namespace:AzrngTools.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:AzrngTools.ViewModels.Encode"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="JWT 解码工作台" />
                        <TextBlock Classes="section-copy" Text="输入 JWT 后会自动解析 Header 和 Payload，适合快速查看载荷内容。" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="Header" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="Payload" />
                        </Border>
                        <Border Classes="badge-pill">
                            <TextBlock Classes="badge-text" Text="自动解析" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1.05*,1.05*,0.9*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="JWT 输入" />
                            <TextBlock Classes="section-copy" Text="支持直接粘贴完整 JWT，也可输入带 `Bearer ` 前缀的令牌，内容变化后会自动尝试解码。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <avaloniaEdit:TextEditor
                                FontFamily="Consolas,monospace"
                                HorizontalScrollBarVisibility="Auto"
                                MinHeight="420"
                                Name="JwtText"
                                Padding="{StaticResource Thickness.8}"
                                behaviors:TextEditorBinding.Text="{Binding Original, Mode=TwoWay}"
                                ShowLineNumbers="True"
                                SyntaxHighlighting="Json"
                                VerticalScrollBarVisibility="Visible"
                                WordWrap="True">
                                <avaloniaEdit:TextEditor.Options>
                                    <avaloniaEdit:TextEditorOptions ShowSpaces="False">
                                        <avaloniaEdit:TextEditorOptions.ColumnRulerPositions>
                                            <system:Int32>10</system:Int32>
                                        </avaloniaEdit:TextEditorOptions.ColumnRulerPositions>
                                    </avaloniaEdit:TextEditorOptions>
                                </avaloniaEdit:TextEditor.Options>
                            </avaloniaEdit:TextEditor>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="解析结果" />
                            <TextBlock Classes="section-copy" Text="Header 和 Payload 分区展示，便于快速检查签发信息、时间字段和业务载荷内容。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.6}">
                                <TextBlock Classes="metric-label" Text="Header" />
                                <TextBox
                                    Grid.Row="1"
                                    AcceptsReturn="True"
                                    Classes="Standard"
                                    Height="150"
                                    IsReadOnly="True"
                                    Text="{Binding HeaderText}"
                                    PlaceholderText="Header" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.6}">
                                <TextBlock Classes="metric-label" Text="Payload" />
                                <TextBox
                                    Grid.Row="1"
                                    AcceptsReturn="True"
                                    Classes="Standard"
                                    Height="230"
                                    IsReadOnly="True"
                                    Text="{Binding PayloadText}"
                                    PlaceholderText="Payload" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Classes="tool-card-soft">
                            <TextBlock
                                Classes="section-copy"
                                Text="当前页面仅做结构解析展示，不验证签名，也不会新增额外的令牌编辑操作。"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="使用说明" />
                            <TextBlock Classes="section-copy" Text="这里不提供显式按钮，继续沿用“输入即解析”的现有行为，减少一次额外点击。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="Small" Text="令牌需要至少包含 Header 与 Payload 两段内容。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="支持 URL Safe Base64 形式，页面会按现有逻辑自动补齐并解码。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="输入无效时，结果区会清空并通过提示消息反馈错误。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
