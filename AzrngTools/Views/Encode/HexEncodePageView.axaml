<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.Encode.HexEncodePageView"
    x:DataType="encode:HexEncodePageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:encode="clr-namespace:AzrngTools.ViewModels.Encode"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="十六进制转换工作台" />
                            <TextBlock Classes="section-copy" Text="把分隔符设置、输入内容和结果展示收口到同一套双列工作区中，适合排查接口字节内容与编码格式。" />
                        </StackPanel>

                        <WrapPanel Grid.Column="1" Classes="tool-actions" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Classes="badge-pill">
                                <TextBlock Classes="badge-text" Text="UTF-8" />
                            </Border>
                            <Border Classes="badge-pill">
                                <TextBlock Classes="badge-text" Text="字节数组" />
                            </Border>
                            <Border Classes="badge-pill">
                                <TextBlock Classes="badge-text" Text="分隔符" />
                            </Border>
                        </WrapPanel>
                    </Grid>

                    <WrapPanel Grid.Row="1" Classes="tool-actions">
                        <Button
                            Command="{Binding StringToHexCommand}"
                            Content="字符串转十六进制"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding HexToStringCommand}"
                            Content="十六进制转字符串"
                            Theme="{DynamicResource SolidButton}" />
                        <Button
                            Command="{Binding BytesToHexCommand}"
                            Content="字节数组转十六进制"
                            Theme="{DynamicResource OutlineButton}" />
                        <Button
                            Command="{Binding HexToBytesCommand}"
                            Content="十六进制转字节数组"
                            Theme="{DynamicResource OutlineButton}" />
                        <Button
                            Command="{Binding CopyResultCommand}"
                            Content="复制结果"
                            Theme="{DynamicResource OutlineButton}" />
                        <Button
                            Command="{Binding ClearCommand}"
                            Content="清空"
                            Theme="{DynamicResource OutlineButton}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="1*,1*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="输入与格式" />
                            <TextBlock Classes="section-copy" Text="支持普通字符串和十六进制文本互转，输入区上方保留分隔符设置，方便连续切换输出格式。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Classes="metric-label" VerticalAlignment="Center" Text="分隔符" />
                                <ComboBox
                                    Grid.Column="1"
                                    SelectedIndex="{Binding SeparatorIndex}"
                                    Theme="{DynamicResource OutlineComboBox}">
                                    <ComboBoxItem Content="空格" Tag=" " />
                                    <ComboBoxItem Content="无" Tag="" />
                                    <ComboBoxItem Content="短横线" Tag="-" />
                                    <ComboBoxItem Content="冒号" Tag=":" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <TextBox
                            Grid.Row="2"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="320"
                            PlaceholderText="请输入要转换的内容"
                            Text="{Binding Original}"
                            TextWrapping="Wrap" />

                        <Border Grid.Row="3" Classes="tool-card-soft">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="metric-label" Text="输入提示" />
                                <TextBlock Classes="Small" Text="• 十六进制输入支持空格、短横线以及 `0x / 0X` 前缀。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="• 字符串类转换按 UTF-8 编码处理。" TextWrapping="Wrap" />
                                <TextBlock Classes="Small" Text="• 十六进制字符长度必须为偶数，否则会直接给出提示。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="处理结果" />
                            <TextBlock Classes="section-copy" Text="无论是单行十六进制输出，还是字节数组逐项说明，都会统一展示在这里，方便直接复制或继续比对。" />
                        </StackPanel>

                        <TextBox
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Classes="Standard"
                            Height="412"
                            IsReadOnly="True"
                            PlaceholderText="处理后的内容会显示在这里"
                            Text="{Binding HandleText}"
                            TextWrapping="Wrap" />

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                <Button
                                    Command="{Binding CopyResultCommand}"
                                    Content="复制结果"
                                    Theme="{DynamicResource OutlineButton}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Classes="section-copy"
                                    Text="结果区保留更高可视高度，兼顾短文本十六进制和多行字节数组说明两类场景。"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="1.05*,0.95*" ColumnSpacing="{StaticResource Space.12}">
                <Border Classes="tool-card-soft">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="使用建议" />
                            <TextBlock Classes="section-copy" Text="适合检查十六进制字符串、字节数组和普通文本之间的转换结果。" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Spacing="{StaticResource Space.8}">
                            <TextBlock Classes="Small" Text="• 如果目标是接口签名串或二进制报文，通常先用“十六进制转字节数组”确认每个字节值。" TextWrapping="Wrap" />
                            <TextBlock Classes="Small" Text="• 输出分隔符只影响十六进制展示形式，不会改变真实字节内容。" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="tool-card-soft">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="动作分组" />
                            <TextBlock Classes="section-copy" Text="覆盖文本向与字节向四种转换，并提供复制与清空辅助操作。" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="{StaticResource Space.10}" RowSpacing="{StaticResource Space.10}">
                            <Border Classes="tool-card-roomy">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="metric-label" Text="文本向" />
                                    <TextBlock Classes="section-copy" Text="字符串转十六进制 / 十六进制转字符串" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Classes="tool-card-roomy">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="metric-label" Text="字节向" />
                                    <TextBlock Classes="section-copy" Text="字节数组转十六进制 / 十六进制转字节数组" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Classes="tool-card-roomy">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="metric-label" Text="输出辅助" />
                                    <TextBlock Classes="section-copy" Text="复制结果" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Classes="tool-card-roomy">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="metric-label" Text="输入辅助" />
                                    <TextBlock Classes="section-copy" Text="清空 / 分隔符切换" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
