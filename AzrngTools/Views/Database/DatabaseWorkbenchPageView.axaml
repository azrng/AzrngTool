<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AzrngTools.ViewModels.Database"
             xmlns:controls="clr-namespace:AzrngTools.Controls.Database"
             xmlns:view="clr-namespace:AzrngTools.Views.Database.Workbench"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="AzrngTools.Views.Database.DatabaseWorkbenchPageView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="WorkbenchPage"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignWidth="1400"
             d:DesignHeight="900">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Panel>
        <Grid Background="{DynamicResource Brush.App.Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Classes="toolbarStrip">
                <Border Classes="toolbarCommandBar">
                    <Grid ColumnDefinitions="Auto,240,Auto,Auto,*"
                          ColumnSpacing="{StaticResource Space.12}">
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource Space.12}"
                                    Margin="{StaticResource Thickness.Right.16}">
                            <Border Classes="dbWorkbenchIdentityBadge">
                                <TextBlock Text="DB"
                                           Classes="dbWorkbenchIdentityText" />
                            </Border>
                            <StackPanel VerticalAlignment="Center"
                                        Spacing="{StaticResource Space.2}">
                                <TextBlock Text="数据库工作台"
                                           Classes="subheading" />
                                <TextBlock Text="连接、浏览、详情与导出统一在一个工作台里完成"
                                           Classes="caption" />
                            </StackPanel>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  Width="240"
                                  ItemsSource="{Binding Connections}"
                                  SelectedItem="{Binding SelectedConnection}"
                                  PlaceholderText="选择连接"
                                  Classes="modern"
                                  MinHeight="36">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="2"
                                Command="{Binding ShowAddConnectionDialogCommand}"
                                Classes="workbenchToolbarAction"
                                ToolTip.Tip="管理数据库连接">
                            <TextBlock Text="管理连接"
                                       FontWeight="Medium" />
                        </Button>

                        <Button Grid.Column="3"
                                Command="{Binding OpenExportDialogCommand}"
                                Classes="workbenchToolbarAction"
                                ToolTip.Tip="导出文档">
                            <TextBlock Text="导出文档"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Border Grid.Column="4"
                                Classes="statusPill"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource Space.6}">
                                <TextBlock Text="●"
                                           Classes="statusPillText" />
                                <TextBlock Text="{Binding CompactConnectionLabel}"
                                           Classes="statusPillText"
                                           MaxWidth="220"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <Grid Grid.Row="1"
                  Margin="{StaticResource Thickness.20}"
                  ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Classes="browserPanel"
                        MinHeight="0">
                    <Grid RowDefinitions="Auto,*,Auto"
                          MinHeight="0">
                        <Border Grid.Row="0"
                                Classes="browserCompactSection">
                            <StackPanel Spacing="{StaticResource Space.12}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{StaticResource Space.12}">
                                    <StackPanel Spacing="{StaticResource Space.2}">
                                        <TextBlock Text="对象浏览器"
                                                   Classes="subheading" />
                                        <TextBlock Text="连接、库选择与对象树集中在左侧，保持持续浏览和快速切换的工作路径。"
                                                   Classes="caption"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Classes="statusPill"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="实时浏览"
                                                   Classes="statusPillText" />
                                    </Border>
                                </Grid>

                                <Grid RowDefinitions="Auto,Auto"
                                      RowSpacing="{StaticResource Space.12}">
                                    <ComboBox ItemsSource="{Binding AvailableDatabases}"
                                              SelectedItem="{Binding SelectedDatabaseName}"
                                              PlaceholderText="请选择数据库"
                                              IsEnabled="{Binding SelectedConnection, Converter={StaticResource NullToBoolConverter}}"
                                              Classes="modern"
                                              HorizontalAlignment="Stretch"
                                              MinHeight="36" />
                                    <TextBox Grid.Row="1"
                                             Text="{Binding #DatabaseTree.SearchText, Mode=TwoWay}"
                                             PlaceholderText="搜索表、视图、存储过程..."
                                             HorizontalAlignment="Stretch"
                                             Classes="modern" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Classes="browserTreeSurface"
                                MinHeight="0">
                            <ScrollViewer Classes="browserTreeScroll"
                                          MinHeight="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          IsScrollChainingEnabled="False">
                                <controls:DatabaseTree x:Name="DatabaseTree"
                                                       MinHeight="0"
                                                       Margin="{StaticResource Thickness.4}"
                                                       RootNode="{Binding BrowserViewModel.FirstRootNode}"
                                                       IsLoading="{Binding BrowserViewModel.IsLoading}"
                                                       LoadingText="{Binding BrowserViewModel.LoadingText}" />
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="{StaticResource Thickness.12}"
                                BorderBrush="{DynamicResource Brush.Panel.Stroke}"
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="{StaticResource Space.10}">
                                <Button Grid.Column="0"
                                        Classes="workbenchSidebarAction"
                                        Command="{Binding RefreshBrowserCommand}"
                                        HorizontalAlignment="Stretch">
                                    <TextBlock Text="刷新"
                                               FontWeight="Medium" />
                                </Button>

                                <Button Grid.Column="1"
                                        Classes="workbenchSidebarAction"
                                        Click="OnClearBrowserSearchClick"
                                        HorizontalAlignment="Stretch">
                                    <TextBlock Text="清空搜索"
                                               FontWeight="Medium" />
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="2"
                      MinWidth="0"
                      MinHeight="0"
                      ClipToBounds="True">
                    <Border Classes="workspaceSurface"
                            MinWidth="0"
                            MinHeight="0"
                            ClipToBounds="True"
                            IsVisible="{Binding ShowOverviewPage}">
                        <ScrollViewer Padding="{StaticResource Thickness.20}"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="{StaticResource Space.16}">
                                <Border Classes="dbWorkbenchHeroCard">
                                    <Grid ColumnDefinitions="*,280"
                                          ColumnSpacing="{StaticResource Space.16}">
                                        <StackPanel Spacing="{StaticResource Space.12}">
                                            <Border Classes="dbWorkbenchHeroBadge"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="DATABASE CONTROL CENTER"
                                                           Classes="dbWorkbenchHeroBadgeText" />
                                            </Border>

                                            <TextBlock Text="先连接，再切库，然后在左侧持续浏览对象"
                                                       Classes="dbWorkbenchHeroTitle"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="连接和数据库确认后，左侧对象树会持续承接后续浏览、详情进入和导出动作。"
                                                       Classes="body"
                                                       TextWrapping="Wrap" />

                                            <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="{StaticResource Space.12}">
                                                <Border Grid.Column="0"
                                                        Classes="dbWorkbenchInfoCard">
                                                    <StackPanel Spacing="{StaticResource Space.4}">
                                                        <TextBlock Text="当前连接"
                                                                   Classes="label" />
                                                        <TextBlock Text="{Binding CompactConnectionLabel}"
                                                                   Classes="dbWorkbenchInfoValue"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        Classes="dbWorkbenchInfoCard">
                                                    <StackPanel Spacing="{StaticResource Space.4}">
                                                        <TextBlock Text="当前数据库"
                                                                   Classes="label" />
                                                        <TextBlock Text="{Binding SelectedDatabaseName, TargetNullValue=未选择数据库}"
                                                                   Classes="dbWorkbenchInfoValue"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="{StaticResource Space.12}">
                                                <Button Classes="workbenchAccentAction"
                                                        Command="{Binding ShowAddConnectionDialogCommand}">
                                                    <TextBlock Text="管理连接" />
                                                </Button>

                                                <Button Classes="workbenchToolbarAction"
                                                        Command="{Binding OpenExportDialogCommand}">
                                                    <TextBlock Text="导出文档" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Classes="dbWorkbenchStatusCard">
                                            <StackPanel Spacing="{StaticResource Space.12}">
                                                <Border Classes="dbWorkbenchStatePill"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding CompactConnectionLabel}"
                                                               Classes="dbWorkbenchStatePillText"
                                                               MaxWidth="200"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>

                                                <StackPanel Spacing="{StaticResource Space.4}">
                                                    <TextBlock Text="工作台状态"
                                                               Classes="subheading" />
                                                    <TextBlock Text="这里只保留当前状态和对象规模，方便快速判断是否已经进入可浏览上下文。"
                                                               Classes="caption"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Grid ColumnDefinitions="*,*"
                                                      RowDefinitions="Auto,Auto"
                                                      ColumnSpacing="{StaticResource Space.12}"
                                                      RowSpacing="{StaticResource Space.12}">
                                                    <Border Grid.Row="0"
                                                            Grid.Column="0"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="可用库"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding AvailableDatabases.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="0"
                                                            Grid.Column="1"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="数据表"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding TableDetailViewModel.Tables.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="1"
                                                            Grid.Column="0"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="视图"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding ViewDetailViewModel.Views.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="1"
                                                            Grid.Column="1"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="存储过程"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding StoredProcedureDetailViewModel.Procedures.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Classes="workspaceSurface"
                            MinWidth="0"
                            MinHeight="0"
                            ClipToBounds="True"
                            IsVisible="{Binding ShowSchemaWorkspace}">
                        <ScrollViewer Classes="schemaWorkspaceScroll">
                            <StackPanel Spacing="{StaticResource Space.16}">
                                <Border Classes="dbWorkbenchHeroCard">
                                    <Grid ColumnDefinitions="*,280"
                                          ColumnSpacing="{StaticResource Space.16}">
                                        <StackPanel Spacing="{StaticResource Space.12}">
                                            <Border Classes="dbWorkbenchHeroBadge"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="SCHEMA WORKSPACE"
                                                           Classes="dbWorkbenchHeroBadgeText" />
                                            </Border>

                                            <TextBlock Text="{Binding CurrentSchema.Name, FallbackValue=架构工作区}"
                                                       Classes="dbWorkbenchHeroTitle"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="{Binding CurrentConnectionLabel}"
                                                       Classes="caption"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="这里承接当前架构的浏览上下文。左侧对象树继续负责导航，右侧则先汇总架构状态，再承接后续表、视图与存储过程详情。"
                                                       Classes="body"
                                                       TextWrapping="Wrap" />

                                            <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="{StaticResource Space.12}">
                                                <Border Grid.Column="0"
                                                        Classes="dbWorkbenchInfoCard">
                                                    <StackPanel Spacing="{StaticResource Space.4}">
                                                        <TextBlock Text="所有者"
                                                                   Classes="label" />
                                                        <TextBlock Text="{Binding CurrentSchema.Owner, FallbackValue=-}"
                                                                   Classes="dbWorkbenchInfoValue" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        Classes="dbWorkbenchInfoCard">
                                                    <StackPanel Spacing="{StaticResource Space.4}">
                                                        <TextBlock Text="架构记录表数"
                                                                   Classes="label" />
                                                        <TextBlock Text="{Binding CurrentSchema.TableCount}"
                                                                   Classes="dbWorkbenchInfoValue" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="{StaticResource Space.12}">
                                                <Button Classes="workbenchAccentAction"
                                                        Command="{Binding OpenExportDialogCommand}">
                                                    <TextBlock Text="导出当前上下文" />
                                                </Button>

                                                <Border Classes="statusPill"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CurrentSchema.Name, StringFormat=当前架构: {0}}"
                                                               Classes="statusPillText" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Classes="dbWorkbenchStatusCard">
                                            <StackPanel Spacing="{StaticResource Space.12}">
                                                <StackPanel Spacing="{StaticResource Space.4}">
                                                    <TextBlock Text="架构摘要"
                                                               Classes="subheading" />
                                                    <TextBlock Text="右侧先给出架构规模和默认状态，进入具体对象前就能建立上下文。"
                                                               Classes="caption"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Grid ColumnDefinitions="*,*"
                                                      RowDefinitions="Auto,Auto"
                                                      ColumnSpacing="{StaticResource Space.12}"
                                                      RowSpacing="{StaticResource Space.12}">
                                                    <Border Grid.Row="0"
                                                            Grid.Column="0"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="数据表"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding TableDetailViewModel.Tables.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="0"
                                                            Grid.Column="1"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="视图"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding ViewDetailViewModel.Views.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="1"
                                                            Grid.Column="0"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="存储过程"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <TextBlock Text="{Binding StoredProcedureDetailViewModel.Procedures.Count}"
                                                                       Classes="dbWorkbenchMiniMetricValue" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="1"
                                                            Grid.Column="1"
                                                            Classes="dbWorkbenchMiniMetricCard">
                                                        <StackPanel Spacing="{StaticResource Space.4}">
                                                            <TextBlock Text="默认架构"
                                                                       Classes="dbWorkbenchMiniMetricLabel" />
                                                            <Grid ColumnDefinitions="Auto,*"
                                                                  ColumnSpacing="{StaticResource Space.8}">
                                                                <Border Classes="booleanBadge positive"
                                                                        IsVisible="{Binding CurrentSchema.IsDefault}">
                                                                    <TextBlock Text="是"
                                                                               Classes="booleanBadgeText positive" />
                                                                </Border>

                                                                <Border Classes="booleanBadge negative"
                                                                        IsVisible="{Binding CurrentSchema.IsDefault, Converter={StaticResource InvertedBoolConverter}}">
                                                                    <TextBlock Text="否"
                                                                               Classes="booleanBadgeText negative" />
                                                                </Border>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="1.35*,*"
                                      ColumnSpacing="{StaticResource Space.16}">
                                    <StackPanel Grid.Column="0"
                                                Spacing="{StaticResource Space.16}">
                                        <Border Classes="dbWorkbenchSectionCard">
                                            <StackPanel Spacing="{StaticResource Space.12}">
                                                <StackPanel Spacing="{StaticResource Space.4}">
                                                    <TextBlock Text="浏览路径"
                                                               Classes="subheading" />
                                                    <TextBlock Text="选中架构后，右侧应该回答两个问题：当前架构里有什么，以及接下来从哪里进入。"
                                                               Classes="caption"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Border Classes="dbWorkbenchStepRow">
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="{StaticResource Space.12}">
                                                        <Border Classes="dbWorkbenchStepBadge">
                                                            <TextBlock Text="1"
                                                                       Classes="dbWorkbenchStepBadgeText" />
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="{StaticResource Space.2}">
                                                            <TextBlock Text="先确认当前架构上下文"
                                                                       Classes="body" />
                                                            <TextBlock Text="顶部状态条与本页摘要一起说明连接、数据库和当前架构，避免后续详情页脱离上下文。"
                                                                       Classes="caption"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Classes="dbWorkbenchStepRow">
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="{StaticResource Space.12}">
                                                        <Border Classes="dbWorkbenchStepBadge">
                                                            <TextBlock Text="2"
                                                                       Classes="dbWorkbenchStepBadgeText" />
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="{StaticResource Space.2}">
                                                            <TextBlock Text="从左侧对象树继续下钻"
                                                                       Classes="body" />
                                                            <TextBlock Text="切到表节点会进入表详情，切到视图和存储过程时也会复用同一套右侧工作区结构。"
                                                                       Classes="caption"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Classes="dbWorkbenchStepRow">
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="{StaticResource Space.12}">
                                                        <Border Classes="dbWorkbenchStepBadge">
                                                            <TextBlock Text="3"
                                                                       Classes="dbWorkbenchStepBadgeText" />
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="{StaticResource Space.2}">
                                                            <TextBlock Text="按需导出与整理"
                                                                       Classes="body" />
                                                            <TextBlock Text="确认架构范围后即可直接导出文档，也可以继续进入对象详情补充字段、参数和 DDL 信息。"
                                                                       Classes="caption"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Classes="dbWorkbenchSectionCard subtle">
                                            <StackPanel Spacing="{StaticResource Space.10}">
                                                <TextBlock Text="对象规模"
                                                           Classes="subheading" />
                                                <TextBlock Text="当前架构里的表、视图和存储过程数量会随加载结果更新，这里显示的是进入详情前的第一层摘要。"
                                                           Classes="caption"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Spacing="{StaticResource Space.16}">
                                        <Border Classes="dbWorkbenchSectionCard">
                                            <StackPanel Spacing="{StaticResource Space.12}">
                                                <StackPanel Spacing="{StaticResource Space.4}">
                                                    <TextBlock Text="当前上下文"
                                                               Classes="subheading" />
                                                    <TextBlock Text="这部分保留给正在工作的架构信息，方便从入口页、架构页和对象详情页之间顺滑切换。"
                                                               Classes="caption"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Border Classes="dbWorkbenchStateRow">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          RowSpacing="{StaticResource Space.4}">
                                                        <TextBlock Text="连接"
                                                                   Classes="label" />
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding CompactConnectionLabel}"
                                                                   Classes="dbWorkbenchStateValue" />
                                                    </Grid>
                                                </Border>

                                                <Border Classes="dbWorkbenchStateRow">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          RowSpacing="{StaticResource Space.4}">
                                                        <TextBlock Text="架构"
                                                                   Classes="label" />
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding CurrentSchema.Name, FallbackValue=未选择架构}"
                                                                   Classes="dbWorkbenchStateValue" />
                                                    </Grid>
                                                </Border>

                                                <Border Classes="dbWorkbenchStateRow">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          RowSpacing="{StaticResource Space.4}">
                                                        <TextBlock Text="所有者"
                                                                   Classes="label" />
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding CurrentSchema.Owner, FallbackValue=-}"
                                                                   Classes="dbWorkbenchStateValue" />
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Classes="dbWorkbenchSectionCard subtle">
                                            <StackPanel Spacing="{StaticResource Space.10}">
                                                <TextBlock Text="后续入口"
                                                           Classes="subheading" />
                                                <TextBlock Text="下一步优先承接表、视图和存储过程详情页。如果你继续点下钻，右侧应该始终保持同一套工作台语义，而不是重新换一种页面语言。"
                                                           Classes="caption"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Classes="workspaceSurface"
                            MinWidth="0"
                            MinHeight="0"
                            ClipToBounds="True"
                            IsVisible="{Binding ShowTableWorkspace}">
                        <view:TableDetailView DataContext="{Binding TableDetailViewModel}" />
                    </Border>

                    <Border Classes="workspaceSurface"
                            MinWidth="0"
                            MinHeight="0"
                            ClipToBounds="True"
                            IsVisible="{Binding ShowViewWorkspace}">
                        <view:ViewDetailView DataContext="{Binding ViewDetailViewModel}" />
                    </Border>

                    <Border Classes="workspaceSurface"
                            MinWidth="0"
                            MinHeight="0"
                            ClipToBounds="True"
                            IsVisible="{Binding ShowProcedureWorkspace}">
                        <view:StoredProcedureDetailView DataContext="{Binding StoredProcedureDetailViewModel}" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>

    </Panel>
</UserControl>





