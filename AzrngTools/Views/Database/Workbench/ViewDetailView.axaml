<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzrngTools.ViewModels.Database"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="720"
             x:Class="AzrngTools.Views.Database.Workbench.ViewDetailView"
             x:CompileBindings="False">

    <Design.DataContext>
        <vm:ViewDetailViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Classes="toolbarStrip"
                IsVisible="{Binding IsLoading}">
            <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource Space.10}">
                <ProgressBar Width="24"
                             Height="18"
                             IsIndeterminate="True" />
                <TextBlock Text="{Binding LoadingText}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Classes="workspaceSurface"
                IsVisible="{Binding ShowEmptyState}">
            <Grid Margin="{StaticResource Thickness.20}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="460"
                            Spacing="{StaticResource Space.12}">
                    <TextBlock Text="暂无视图"
                               Classes="heading"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="请先在左侧对象树中选择一个架构，以加载该架构下的视图工作区。"
                               Classes="caption"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="320,16,*"
              IsVisible="{Binding ShowSplitWorkspace}">
            <Border Grid.Column="0"
                    Classes="browserPanel">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Classes="browserCompactSection">
                        <StackPanel Spacing="{StaticResource Space.12}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Space.12}">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Text="视图列表"
                                               Classes="subheading" />
                                    <TextBlock Text="左侧保留当前架构下的视图清单，便于快速切换对象并连续查看定义。"
                                               Classes="caption"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Classes="statusPill"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="DDL 只读"
                                               Classes="statusPillText" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Classes="browserTreeSurface">
                        <DataGrid ItemsSource="{Binding Views}"
                                  SelectedItem="{Binding SelectedView}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称"
                                                    Binding="{Binding Name}"
                                                    Width="180" />
                                <DataGridTextColumn Header="备注"
                                                    Binding="{Binding Comment}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Classes="workspaceSurface">
                <Grid>
                    <Grid IsVisible="{Binding HasSelectedView, Converter={StaticResource InvertedBoolConverter}}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="460"
                                    Spacing="{StaticResource Space.12}">
                            <TextBlock Text="请选择视图"
                                       Classes="heading"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="请在左侧列表中选择一个视图，右侧会展示该视图的备注、时间信息与 DDL 定义。"
                                       Classes="caption"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Padding="{StaticResource Thickness.20}"
                                  IsVisible="{Binding HasSelectedView}">
                        <StackPanel Spacing="{StaticResource Space.16}">
                            <Border Classes="toolbarCommandBar">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{StaticResource Space.12}">
                                    <StackPanel Spacing="{StaticResource Space.4}">
                                        <TextBlock Text="{Binding SelectedView.Name}"
                                                   Classes="heading" />
                                        <TextBlock Text="{Binding SelectedView.Schema, StringFormat=架构: {0}}"
                                                   Classes="caption" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding RefreshCommand}"
                                            Classes="toolbarAction"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="重新加载"
                                                   FontWeight="Medium" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid ColumnDefinitions="*,*,*"
                                  ColumnSpacing="{StaticResource Space.12}">
                                <Border Grid.Column="0"
                                        Classes="schemaMetricCard">
                                    <StackPanel Spacing="{StaticResource Space.4}">
                                        <TextBlock Text="备注"
                                                   Classes="schemaMetricLabel" />
                                        <TextBlock Text="{Binding ViewCommentDisplay}"
                                                   Classes="schemaMetricValue" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Classes="schemaMetricCard">
                                    <StackPanel Spacing="{StaticResource Space.4}">
                                        <TextBlock Text="创建时间"
                                                   Classes="schemaMetricLabel" />
                                        <TextBlock Text="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}"
                                                   Classes="schemaMetricValue" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Classes="schemaMetricCard">
                                    <StackPanel Spacing="{StaticResource Space.4}">
                                        <TextBlock Text="更新时间"
                                                   Classes="schemaMetricLabel" />
                                        <TextBlock Text="{Binding ModifyTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}"
                                                   Classes="schemaMetricValue" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="detailGridShell">
                                <Grid RowDefinitions="Auto,*">
                                    <Border Grid.Row="0"
                                            Classes="detailGridHeader">
                                        <Grid RowDefinitions="Auto,Auto"
                                              RowSpacing="{StaticResource Space.4}">
                                            <TextBlock Text="DDL 定义"
                                                       Classes="subheading" />
                                            <TextBlock Grid.Row="1"
                                                       Text="展示当前视图的结构定义，便于直接查看与复制。"
                                                       Classes="caption" />
                                        </Grid>
                                    </Border>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding ViewDefinitionDisplay}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             FontFamily="{DynamicResource Font.Family.Monospace}"
                                             Padding="{StaticResource Thickness.16}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Classes="workspaceSurface"
                IsVisible="{Binding ShowDetailOnly}">
            <Grid>
                <Grid IsVisible="{Binding HasSelectedView, Converter={StaticResource InvertedBoolConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="460"
                                Spacing="{StaticResource Space.12}">
                        <TextBlock Text="请选择视图"
                                   Classes="heading"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="请在左侧对象树中选择一个视图，右侧会展示该视图的备注、时间信息与 DDL 定义。"
                                   Classes="caption"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Padding="{StaticResource Thickness.20}"
                              IsVisible="{Binding HasSelectedView}">
                    <StackPanel Spacing="{StaticResource Space.16}">
                        <Border Classes="toolbarCommandBar">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Space.12}">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Text="{Binding SelectedView.Name}"
                                               Classes="heading" />
                                    <TextBlock Text="{Binding SelectedView.Schema, StringFormat=架构: {0}}"
                                               Classes="caption" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding RefreshCommand}"
                                        Classes="toolbarAction"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="重新加载"
                                               FontWeight="Medium" />
                                </Button>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="{StaticResource Space.12}">
                            <Border Grid.Column="0"
                                    Classes="schemaMetricCard">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Text="备注"
                                               Classes="schemaMetricLabel" />
                                    <TextBlock Text="{Binding ViewCommentDisplay}"
                                               Classes="schemaMetricValue" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Classes="schemaMetricCard">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Text="创建时间"
                                               Classes="schemaMetricLabel" />
                                    <TextBlock Text="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}"
                                               Classes="schemaMetricValue" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Classes="schemaMetricCard">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Text="更新时间"
                                               Classes="schemaMetricLabel" />
                                    <TextBlock Text="{Binding ModifyTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}"
                                               Classes="schemaMetricValue" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Classes="detailGridShell">
                            <Grid RowDefinitions="Auto,*">
                                <Border Grid.Row="0"
                                        Classes="detailGridHeader">
                                    <Grid RowDefinitions="Auto,Auto"
                                          RowSpacing="{StaticResource Space.4}">
                                        <TextBlock Text="DDL 定义"
                                                   Classes="subheading" />
                                        <TextBlock Grid.Row="1"
                                                   Text="展示当前视图的结构定义，便于直接查看与复制。"
                                                   Classes="caption" />
                                    </Grid>
                                </Border>

                                <TextBox Grid.Row="1"
                                         Text="{Binding ViewDefinitionDisplay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="{DynamicResource Font.Family.Monospace}"
                                         Padding="{StaticResource Thickness.16}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
