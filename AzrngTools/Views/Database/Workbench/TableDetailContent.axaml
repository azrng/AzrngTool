<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzrngTools.ViewModels.Database"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="AzrngTools.Views.Database.Workbench.TableDetailContent"
             x:CompileBindings="False"
             x:Name="RootContent">

    <Design.DataContext>
        <vm:TableDetailViewModel />
    </Design.DataContext>

    <Grid>
        <Grid IsVisible="{Binding HasSelectedTable, Converter={StaticResource InvertedBoolConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="460"
                        Spacing="{StaticResource Space.12}">
                <TextBlock Text="请选择数据表"
                           Classes="heading"
                           HorizontalAlignment="Center" />
                <TextBlock Text="请在左侧选择一个数据表，右侧会展示该表的备注、规模信息、字段、索引以及生成的 DDL。"
                           Classes="caption"
                           HorizontalAlignment="Center"
                           MaxWidth="460"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <ScrollViewer Padding="{StaticResource Thickness.20}"
                      IsVisible="{Binding HasSelectedTable}">
            <StackPanel Spacing="{StaticResource Space.16}">
                <Border Classes="toolbarCommandBar">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="{StaticResource Space.12}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Text="{Binding SelectedTable.Name}"
                                       Classes="heading" />
                            <TextBlock Text="{Binding SelectedTable.Schema, StringFormat=架构: {0}}"
                                       Classes="caption" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource Space.10}"
                                    VerticalAlignment="Top">
                            <Button Click="OnEditTableCommentClick"
                                    Classes="toolbarAction"
                                    IsVisible="{Binding CanEditComments}">
                                <TextBlock Text="编辑备注" />
                            </Button>
                            <Button Command="{Binding RefreshCommand}"
                                    Classes="toolbarAction">
                                <TextBlock Text="重新加载" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="{StaticResource Space.12}">
                    <Border Grid.Column="0"
                            Classes="schemaMetricCard">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Text="备注"
                                       Classes="schemaMetricLabel" />
                            <TextBlock Text="{Binding TableCommentDisplayText}"
                                       Classes="schemaMetricValue" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="schemaMetricCard">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Text="行数"
                                       Classes="schemaMetricLabel" />
                            <TextBlock Text="{Binding RowCountDisplay}"
                                       Classes="schemaMetricValue prominent" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Classes="schemaMetricCard">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Text="创建时间"
                                       Classes="schemaMetricLabel" />
                            <TextBlock Text="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}"
                                       Classes="schemaMetricValue" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Classes="schemaMetricCard">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Text="更新时间"
                                       Classes="schemaMetricLabel" />
                            <TextBlock Text="{Binding ModifyTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=-}"
                                       Classes="schemaMetricValue" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Classes="detailGridShell">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                Classes="detailGridHeader">
                            <StackPanel Spacing="{StaticResource Space.10}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{StaticResource Space.12}">
                                    <StackPanel Spacing="{StaticResource Space.4}">
                                        <TextBlock Text="数据表详情"
                                                   Classes="subheading" />
                                        <TextBlock Text="在字段、索引和 DDL 之间切换查看当前数据表的结构信息。"
                                                   Classes="caption" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Classes="statusPill"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding SelectedTable.Name}"
                                                   Classes="statusPillText" />
                                    </Border>
                                </Grid>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="{StaticResource Space.4}">
                                    <Button x:Name="TabColumnsButton"
                                            Command="{Binding SelectTabCommand}"
                                            CommandParameter="columns"
                                            Classes="tabButton">
                                        <TextBlock Text="字段" />
                                    </Button>
                                    <Button x:Name="TabIndexesButton"
                                            Command="{Binding SelectTabCommand}"
                                            CommandParameter="indexes"
                                            Classes="tabButton">
                                        <TextBlock Text="索引" />
                                    </Button>
                                    <Button x:Name="TabDdlButton"
                                            Command="{Binding SelectTabCommand}"
                                            CommandParameter="ddl"
                                            Classes="tabButton">
                                        <TextBlock Text="DDL" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid IsVisible="{Binding ShowColumnsTab}"
                                  RowDefinitions="Auto,*">
                                <Border Grid.Row="0"
                                        Margin="{StaticResource Thickness.12}"
                                        Classes="toolbarStatCard"
                                        IsVisible="{Binding ShowColumnsInfoBanner}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Text="当前字段信息为按元数据生成的只读文本视图。"
                                           Classes="caption"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Command="{Binding DismissColumnsBannerCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="{StaticResource Thickness.10.2}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="×"
                                               Classes="caption" />
                                </Button>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1"
                                      Margin="{StaticResource Thickness.12}">
                            <Border Classes="detailGridShell"
                                    IsVisible="{Binding HasColumns}">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <Grid RowDefinitions="Auto,*">
                                        <Border Grid.Row="0"
                                                Classes="detailGridHeader">
                                            <Grid ColumnDefinitions="44,150,190,160,72,64,64,74,120,92"
                                                  ColumnSpacing="{StaticResource Space.12}">
                                                <TextBlock Grid.Column="0" Text="#" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="1" Text="列名" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="2" Text="数据类型" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="3" Text="备注说明" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="4" Text="长度" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="主键" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="6" Text="自增" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="7" Text="允许空" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="8" Text="默认值" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="9" Text="操作" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Columns}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="detailGridRow">
                                                            <Grid ColumnDefinitions="44,150,190,160,72,64,64,74,120,92"
                                                                  ColumnSpacing="{StaticResource Space.12}">
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding OrdinalPosition}"
                                                                           Classes="detailGridCell secondary center" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Name}"
                                                                           Classes="detailGridCell primary"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip.Tip="{Binding Name}" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding DataType}"
                                                                           Classes="detailGridCell mono"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding Comment, TargetNullValue=-}"
                                                                           Classes="detailGridCell secondary"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip.Tip="{Binding Comment, TargetNullValue=-}" />
                                                                <TextBlock Grid.Column="4"
                                                                           Text="{Binding Length}"
                                                                           Classes="detailGridCell center" />

                                                                <Grid Grid.Column="5">
                                                                    <Border Classes="booleanBadge positive"
                                                                            IsVisible="{Binding IsPrimaryKey}">
                                                                        <TextBlock Text="是"
                                                                                   Classes="booleanBadgeText positive" />
                                                                    </Border>
                                                                    <Border Classes="booleanBadge negative"
                                                                            IsVisible="{Binding IsPrimaryKey, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <TextBlock Text="否"
                                                                                   Classes="booleanBadgeText negative" />
                                                                    </Border>
                                                                </Grid>

                                                                <Grid Grid.Column="6">
                                                                    <Border Classes="booleanBadge positive"
                                                                            IsVisible="{Binding IsIdentity}">
                                                                        <TextBlock Text="是"
                                                                                   Classes="booleanBadgeText positive" />
                                                                    </Border>
                                                                    <Border Classes="booleanBadge negative"
                                                                            IsVisible="{Binding IsIdentity, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <TextBlock Text="否"
                                                                                   Classes="booleanBadgeText negative" />
                                                                    </Border>
                                                                </Grid>

                                                                <Grid Grid.Column="7">
                                                                    <Border Classes="booleanBadge positive"
                                                                            IsVisible="{Binding IsNullable}">
                                                                        <TextBlock Text="是"
                                                                                   Classes="booleanBadgeText positive" />
                                                                    </Border>
                                                                    <Border Classes="booleanBadge negative"
                                                                            IsVisible="{Binding IsNullable, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <TextBlock Text="否"
                                                                                   Classes="booleanBadgeText negative" />
                                                                    </Border>
                                                                </Grid>

                                                                <TextBlock Grid.Column="8"
                                                                           Text="{Binding DefaultValue, TargetNullValue=-}"
                                                                           Classes="detailGridCell mono secondary"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip.Tip="{Binding DefaultValue, TargetNullValue=-}" />
                                                                <Button Grid.Column="9"
                                                                        Click="OnEditColumnCommentClick"
                                                                        Tag="{Binding}"
                                                                        Classes="inlineAction"
                                                                        IsVisible="{Binding #RootContent.DataContext.CanEditComments}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="编辑" />
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Text="暂无字段数据"
                                       Classes="caption"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ShowColumnsEmptyState}" />
                                </Grid>
                            </Grid>

                            <Grid IsVisible="{Binding ShowIndexesTab}"
                                  RowDefinitions="Auto,*">
                                <Border Grid.Row="0"
                                        Margin="{StaticResource Thickness.12}"
                                        Classes="toolbarStatCard"
                                        IsVisible="{Binding ShowIndexesInfoBanner}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Text="当前索引信息为按元数据生成的只读文本视图。"
                                           Classes="caption"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Command="{Binding DismissIndexesBannerCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="{StaticResource Thickness.10.2}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="×"
                                               Classes="caption" />
                                </Button>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1"
                                      Margin="{StaticResource Thickness.12}">
                            <Border Classes="detailGridShell"
                                    IsVisible="{Binding HasIndexes}">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <Grid RowDefinitions="Auto,*">
                                        <Border Grid.Row="0"
                                                Classes="detailGridHeader">
                                            <Grid ColumnDefinitions="220,160,70,70,70,320"
                                                  ColumnSpacing="{StaticResource Space.12}">
                                                <TextBlock Grid.Column="0" Text="索引名" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="1" Text="类型" Classes="detailGridHeaderText" />
                                                <TextBlock Grid.Column="2" Text="唯一" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="主键" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="升序" Classes="detailGridHeaderText" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="字段" Classes="detailGridHeaderText" />
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Indexes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="detailGridRow">
                                                            <Grid ColumnDefinitions="220,160,70,70,70,320"
                                                                  ColumnSpacing="{StaticResource Space.12}">
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Name}"
                                                                           Classes="detailGridCell primary"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding IndexType}"
                                                                           Classes="detailGridCell secondary"
                                                                           TextTrimming="CharacterEllipsis" />

                                                                <Grid Grid.Column="2">
                                                                    <Border Classes="booleanBadge positive"
                                                                            IsVisible="{Binding IsUnique}">
                                                                        <TextBlock Text="是"
                                                                                   Classes="booleanBadgeText positive" />
                                                                    </Border>
                                                                    <Border Classes="booleanBadge negative"
                                                                            IsVisible="{Binding IsUnique, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <TextBlock Text="否"
                                                                                   Classes="booleanBadgeText negative" />
                                                                    </Border>
                                                                </Grid>

                                                                <Grid Grid.Column="3">
                                                                    <Border Classes="booleanBadge positive"
                                                                            IsVisible="{Binding IsPrimaryKey}">
                                                                        <TextBlock Text="是"
                                                                                   Classes="booleanBadgeText positive" />
                                                                    </Border>
                                                                    <Border Classes="booleanBadge negative"
                                                                            IsVisible="{Binding IsPrimaryKey, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <TextBlock Text="否"
                                                                                   Classes="booleanBadgeText negative" />
                                                                    </Border>
                                                                </Grid>

                                                                <Grid Grid.Column="4">
                                                                    <Border Classes="booleanBadge positive"
                                                                            IsVisible="{Binding IsAscending}">
                                                                        <TextBlock Text="是"
                                                                                   Classes="booleanBadgeText positive" />
                                                                    </Border>
                                                                    <Border Classes="booleanBadge negative"
                                                                            IsVisible="{Binding IsAscending, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <TextBlock Text="否"
                                                                                   Classes="booleanBadgeText negative" />
                                                                    </Border>
                                                                </Grid>

                                                                <TextBlock Grid.Column="5"
                                                                           Text="{Binding Columns}"
                                                                           Classes="detailGridCell mono secondary"
                                                                           TextWrapping="Wrap" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Text="暂无索引数据"
                                       Classes="caption"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ShowIndexesEmptyState}" />
                                </Grid>
                            </Grid>

                            <Grid IsVisible="{Binding ShowDdlTab}"
                                  RowDefinitions="Auto,*">
                                <Border Grid.Row="0"
                                        Margin="{StaticResource Thickness.12}"
                                        Classes="toolbarStatCard"
                                        IsVisible="{Binding ShowDdlInfoBanner}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="{StaticResource Space.10}">
                                <TextBlock Text="当前 DDL 为基于已加载元数据生成的回退脚本。"
                                           Classes="caption"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Command="{Binding DismissDdlBannerCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="{StaticResource Thickness.10.2}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="×"
                                               Classes="caption" />
                                </Button>
                                    </Grid>
                                </Border>

                                <TextBox Grid.Row="1"
                                 Margin="{StaticResource Thickness.12}"
                                 Text="{Binding TableDefinitionDisplay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 FontFamily="{DynamicResource Font.Family.Monospace}"
                                 Padding="{StaticResource Thickness.16}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
