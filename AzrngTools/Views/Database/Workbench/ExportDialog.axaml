<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AzrngTools.ViewModels.Database"
        xmlns:models="using:AzrngTools.Models.Database"
        xmlns:dto="using:AzrngTools.Models.Database.DTOs"
        mc:Ignorable="d"
        x:Class="AzrngTools.Views.Database.Workbench.ExportDialog"
        x:CompileBindings="False"
        x:DataType="vm:ExportDialogViewModel"
        x:Name="ExportDialogWindow"
        MinWidth="960" MinHeight="620">

    <Design.DataContext>
        <vm:ExportDialogViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.exportDialogSurface">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}" />
        </Style>

        <Style Selector="Border.exportSectionCard">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="Border.exportTag">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style Selector="TextBlock.exportTagText">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}" />
        </Style>

        <Style Selector="TextBlock.exportSectionTitle">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodyLarge}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>

        <Style Selector="TextBlock.exportSectionHint">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TreeView.exportTree">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="TreeView.exportTree TreeViewItem">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TreeView.exportTree TreeViewItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}" />
        </Style>

        <Style Selector="TreeView.exportTree TreeViewItem:selected">
            <Setter Property="Background" Value="{DynamicResource Brush.Nav.SelectedBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>

        <Style Selector="TreeView.exportTree TreeViewItem > Border">
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Border.exportDocumentTypeCard">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="Button.exportDocumentTypeButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>

        <Style Selector="Button.exportDocumentTypeButton /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="Border.exportDocumentTypeCard.markdown">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
        </Style>

        <Style Selector="Border.exportDocumentTypeCard.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Border.exportDocumentTypeBadge">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="Border.exportDocumentTypeBadge.excel">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
        </Style>

        <Style Selector="TextBlock.exportDocumentTypeBadgeText">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Bold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
        </Style>

        <Style Selector="TextBlock.exportDocumentTypeBadgeText.excel">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
        </Style>

        <Style Selector="TextBlock.exportDocumentTypeTitle">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
        </Style>

        <Style Selector="TextBlock.exportDocumentTypeDescription">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource Brush.App.Background}">
        <Border Margin="18"
                Padding="18"
                Classes="exportDialogSurface">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="18">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                        <TextBlock Text="导出文档"
                                   Classes="heading" />
                        <TextBlock Text="选择要导出的表，然后配置文档名称和输出位置。"
                                   Classes="caption" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Classes="exportTag"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding ConnectionSummary}"
                                   Classes="exportTagText" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="1.25*,0.95*"
                      ColumnSpacing="18">
                    <Border Grid.Column="0"
                            Classes="exportSectionCard">
                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="导出对象"
                                           Classes="exportSectionTitle" />
                                <TextBlock Text="左侧对象树与对象浏览器中的表保持一致，在节点前勾选后即可导出。"
                                           Classes="exportSectionHint" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Classes="toolbarStatCard">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">
                                    <Border Classes="metricIconBadge">
                                        <TextBlock Text="DB"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Accent.Strong}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Spacing="2">
                                        <TextBlock Text="{Binding ConnectionName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" />
                                        <TextBlock Text="{Binding DatabaseLabel}"
                                                   Classes="caption" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Classes="browserTreeSurface"
                                    Margin="0">
                                <Grid>
                                    <ScrollViewer IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                                        <StackPanel Margin="6"
                                                    Spacing="10">
                                            <Border Classes="exportSectionCard"
                                                    IsVisible="{Binding HasLoadError}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="对象加载失败"
                                                               Classes="exportSectionTitle" />
                                                    <TextBlock Text="{Binding LoadErrorMessage}"
                                                               Classes="exportSectionHint" />
                                                    <Button Command="{Binding RetryLoadCommand}"
                                                            Classes="modern"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="重新加载" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="exportSectionCard"
                                                    IsVisible="{Binding HasObjects, Converter={StaticResource InvertedBoolConverter}}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="暂无可导出的对象"
                                                               Classes="exportSectionTitle" />
                                                    <TextBlock Text="当前连接下没有加载到可导出的表。"
                                                               Classes="exportSectionHint" />
                                                </StackPanel>
                                            </Border>

                                            <TreeView Classes="exportTree"
                                                      ItemsSource="{Binding ExportRootChildren}"
                                                      IsVisible="{Binding HasObjects}">
                                                <TreeView.DataTemplates>
                                                    <TreeDataTemplate DataType="models:TreeNodeItem"
                                                                      ItemsSource="{Binding Children}">
                                                        <Grid ColumnDefinitions="Auto,Auto,8,*"
                                                              Margin="0,3">
                                                            <CheckBox Grid.Column="0"
                                                                      IsVisible="{Binding ShowExportCheckBox}"
                                                                      IsThreeState="True"
                                                                      IsChecked="{Binding IsExportChecked, Mode=TwoWay}"
                                                                      VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding IconGlyph}"
                                                                       FontSize="15"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding DisplayName}"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                    </TreeDataTemplate>
                                                </TreeView.DataTemplates>
                                            </TreeView>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <StackPanel IsVisible="{Binding IsLoading}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="12">
                                        <ProgressBar Width="220"
                                                     IsIndeterminate="True" />
                                        <TextBlock Text="{Binding LoadingText}"
                                                   Classes="caption"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="exportSectionCard">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="导出参数"
                                           Classes="exportSectionTitle" />
                                <TextBlock Text="{Binding DocumentTypeHint}"
                                           Classes="exportSectionHint" />
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Spacing="8">
                                <TextBlock Text="文档名称"
                                           Classes="label" />
                                <TextBox Text="{Binding DocumentName}"
                                         PlaceholderText="请输入文档名称"
                                         Classes="modern" />
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Spacing="8">
                                <TextBlock Text="输出路径"
                                           Classes="label" />
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <TextBox Text="{Binding OutputDirectory}"
                                             IsReadOnly="True"
                                             Classes="modern" />
                                    <Button Grid.Column="1"
                                            Click="OnBrowseOutputDirectoryClick"
                                            Classes="secondary">
                                        <TextBlock Text="浏览..."
                                                   FontWeight="Medium" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                        Spacing="8">
                                <TextBlock Text="文档类型"
                                           Classes="label" />
                                <StackPanel Spacing="10">
                                    <Button Command="{Binding SelectDocumentTypeCommand}"
                                            CommandParameter="{x:Static dto:ExportDocumentType.Excel}"
                                            Classes="exportDocumentTypeButton">
                                                <Border Classes="exportDocumentTypeCard"
                                                        Classes.selected="{Binding IsExcelSelected}">
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="12">
                                                <Border Classes="exportDocumentTypeBadge excel">
                                                    <TextBlock Text="X"
                                                               Classes="exportDocumentTypeBadgeText excel" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="4">
                                                    <TextBlock Text="Excel"
                                                               Classes="exportDocumentTypeTitle" />
                                                    <TextBlock Text="按勾选对象生成结构化 Excel 文档，适合整理和交付。"
                                                               Classes="exportDocumentTypeDescription" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <Button Command="{Binding SelectDocumentTypeCommand}"
                                            CommandParameter="{x:Static dto:ExportDocumentType.Markdown}"
                                            Classes="exportDocumentTypeButton">
                                        <Border Classes="exportDocumentTypeCard markdown"
                                                Classes.selected="{Binding IsMarkdownSelected}">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <Border Classes="exportDocumentTypeBadge">
                                                    <TextBlock Text="MD"
                                                               Classes="exportDocumentTypeBadgeText" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="4">
                                                    <TextBlock Text="Markdown"
                                                               Classes="exportDocumentTypeTitle" />
                                                    <TextBlock Text="输出轻量结构文档，便于阅读、提交仓库和二次编辑。"
                                                               Classes="exportDocumentTypeDescription" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource Brush.Panel.Stroke}"
                        BorderThickness="0,1,0,0"
                        Padding="0,16,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="12">
                        <TextBlock Text="{Binding SelectionSummary}"
                                   Classes="caption"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Command="{Binding CancelCommand}"
                                Classes="secondary"
                                Padding="20,10">
                            <TextBlock Text="取消"
                                       FontWeight="Medium" />
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding ExportCommand}"
                                Classes="modern"
                                Padding="24,10">
                            <TextBlock Text="导出"
                                       FontWeight="SemiBold" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
