<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AzrngTools.ViewModels.Database"
        xmlns:controls="using:AzrngTools.Controls.Database"
        mc:Ignorable="d"
        d:DesignWidth="1140"
        d:DesignHeight="720"
        x:Class="AzrngTools.Views.Database.Workbench.ConnectionDialog"
        x:CompileBindings="False"
        x:DataType="vm:ConnectionDialogViewModel"
        x:Name="MainWindow"
        Title="连接管理"
        Width="1140"
        Height="720"
        MinWidth="1040"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Icon="/Assets/avalonia-logo.ico">

    <Design.DataContext>
        <vm:ConnectionDialogViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.connectionDialogSurface">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Display}" />
        </Style>

        <Style Selector="Border.connectionDialogDivider">
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
        </Style>

        <Style Selector="Border.connectionDialogSectionDivider">
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="Border.connectionListCard">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
        </Style>

        <Style Selector="Border.connectionDialogBadge">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogBadgeText">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogTitle">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodyLarge}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogSubtitle">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBlock.connectionDialogMeta">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogName">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodyLarge}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogHost">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        </Style>

        <Style Selector="Border.connectionDialogHint">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
        </Style>

        <Style Selector="Border.connectionDialogErrorBanner">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Danger}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogErrorTitle">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error.Text}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
        </Style>

        <Style Selector="TextBlock.connectionDialogErrorText">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error.Text}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
        </Style>

        <Style Selector="Button.connectionTypeCard">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>

        <Style Selector="Button.connectionTypeCard /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style Selector="Button.connectionTypeCard:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.connectionTypeCard:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.connectionTypeCard:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.connectionTypeCard:focus-visible /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.connectionTypeCard:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Border.connectionTypeSurface">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.2XL}" />
        </Style>

        <Style Selector="Button.connectionTypeCard:pointerover Border.connectionTypeSurface">
            <Setter Property="Background" Value="{DynamicResource Brush.Nav.HoverBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
        </Style>

        <Style Selector="Button.connectionTypeCard:disabled Border.connectionTypeSurface">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="Opacity" Value="0.76" />
        </Style>

        <Style Selector="Border.connectionTypeAccentBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="CornerRadius" Value="16,16,0,0" />
        </Style>

        <Style Selector="Button.connectionTypeCard:disabled Border.connectionTypeAccentBar">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Stroke}" />
        </Style>

        <Style Selector="Border.connectionTypeBadge">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
        </Style>

        <Style Selector="Button.connectionTypeCard:disabled Border.connectionTypeBadge">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
        </Style>

        <Style Selector="TextBlock.connectionTypeBadgeText">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Bold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.connectionTypeCard:disabled TextBlock.connectionTypeBadgeText">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        </Style>

        <Style Selector="TextBlock.connectionTypeName">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.connectionTypeHint">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="Border.connectionTypeState">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Soft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}" />
            <Setter Property="Padding" Value="{StaticResource Thickness.10.4}" />
        </Style>

        <Style Selector="Button.connectionTypeCard:disabled Border.connectionTypeState">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
        </Style>

        <Style Selector="TextBlock.connectionTypeStateText">
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.connectionTypeCard:disabled TextBlock.connectionTypeStateText">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        </Style>

        <Style Selector="Button.connectionAction">
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource Font.Weight.Medium}" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.XL}" />
        </Style>

        <Style Selector="Button.connectionAction.primary">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Strong}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.connectionAction.primary:pointerover">
            <Setter Property="Opacity" Value="0.92" />
        </Style>

        <Style Selector="Button.connectionAction.secondary">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.SubtleBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Panel.Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.connectionAction.secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
        </Style>

        <Style Selector="ListBox.savedConnections">
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.savedConnections ListBoxItem:selected Border.connectionListCard">
            <Setter Property="Background" Value="{DynamicResource Brush.Panel.HeroBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
        </Style>
    </Window.Styles>

    <Grid Background="{DynamicResource Brush.App.Background}">
        <Panel IsHitTestVisible="False"
               ZIndex="9999">
            <StackPanel x:Name="ToastContainer"
                        Margin="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Spacing="8" />
        </Panel>

        <Grid Margin="10"
              ColumnDefinitions="286,14,*">
            <Border Grid.Column="0"
                    Classes="connectionDialogSurface">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Grid.Row="0"
                            Padding="16"
                            Classes="connectionDialogSectionDivider">
                        <Grid ColumnDefinitions="*,52"
                              ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchText}"
                                     Watermark="搜索连接"
                                     Height="46"
                                     Classes="modern" />
                            <Button Grid.Column="1"
                                    Width="52"
                                    Height="46"
                                    Command="{Binding CreateNewConnectionCommand}"
                                    Classes="connectionAction primary">
                                <TextBlock Text="+"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding FilteredConnections}"
                                 SelectedItem="{Binding SelectedSavedConnection}"
                                 Classes="savedConnections"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Margin="8,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="connectionListCard"
                                            Margin="6,4"
                                            Padding="12">
                                        <Grid ColumnDefinitions="42,*"
                                              ColumnSpacing="12">
                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="14"
                                                    Background="{Binding DatabaseTypeBackgroundColor}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding DatabaseTypeIcon}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="4">
                                                <TextBlock Text="{Binding Name}"
                                                           Classes="connectionDialogName"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Host}"
                                                           Classes="connectionDialogHost"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border IsVisible="{Binding HasFilteredConnections, Converter={StaticResource InvertedBoolConverter}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="24">
                            <StackPanel Spacing="12"
                                        HorizontalAlignment="Center">
                                <Border Width="56"
                                        Height="56"
                                        Classes="connectionDialogBadge">
                                    <TextBlock Text="DB"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Classes="connectionDialogBadgeText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="暂无连接"
                                           Classes="connectionDialogTitle"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="点击右上角 + 新建连接"
                                           Classes="connectionDialogMeta"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="16"
                            Classes="connectionDialogDivider">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="已保存连接"
                                       VerticalAlignment="Center"
                                       Classes="connectionDialogMeta" />
                            <Button Grid.Column="1"
                                    Width="42"
                                    Height="36"
                                    Command="{Binding DeleteConnectionCommand}"
                                    Classes="connectionAction secondary">
                                <TextBlock Text="🗑"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Border IsVisible="{Binding ShowDatabaseTypeSelector}"
                        Classes="connectionDialogSurface">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                Padding="28,22"
                                Classes="connectionDialogSectionDivider">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="选择数据库类型"
                                               Classes="connectionDialogTitle" />
                                    <TextBlock Text="当前仅开放 PostgresSql 和 MySql，可按你的业务类型继续配置连接。"
                                               Classes="connectionDialogSubtitle" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Width="56"
                                        Height="56"
                                        Classes="connectionDialogBadge">
                                    <TextBlock Text="DB"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Classes="connectionDialogBadgeText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      Padding="24">
                            <ItemsControl ItemsSource="{Binding DatabaseTypeCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="176"
                                                Height="138"
                                                Margin="0,0,18,18"
                                                Classes="connectionTypeCard"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                IsEnabled="{Binding IsEnabled}"
                                                Command="{Binding $parent[Window].DataContext.SelectDatabaseTypeCommand}"
                                                CommandParameter="{Binding Type}">
                                            <Border Classes="connectionTypeSurface">
                                                <Grid RowDefinitions="4,*">
                                                    <Border Classes="connectionTypeAccentBar" />

                                                    <StackPanel Grid.Row="1"
                                                                Spacing="10"
                                                                Margin="18,16"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <Border Classes="connectionTypeBadge">
                                                            <TextBlock Text="{Binding Icon}"
                                                                       Classes="connectionTypeBadgeText" />
                                                        </Border>

                                                        <TextBlock Text="{Binding Name}"
                                                                   Classes="connectionTypeName" />

                                                        <Border Classes="connectionTypeState"
                                                                HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding Hint}"
                                                                       Classes="connectionTypeStateText" />
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border IsVisible="{Binding ShowEditor}"
                        Classes="connectionDialogSurface">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0"
                                Padding="28,20"
                                Background="{DynamicResource Brush.Panel.HeroBackground}"
                                BorderBrush="{DynamicResource Brush.Accent.Border}"
                                BorderThickness="0,0,0,1">

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="20">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding CurrentEditorTitle}"
                                               Classes="connectionDialogTitle" />
                                    <TextBlock Text="{Binding CurrentEditorDescription}"
                                               Classes="connectionDialogSubtitle"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Width="56"
                                        Height="56"
                                        CornerRadius="16"
                                        Background="{Binding CurrentBrandSoftColor}"
                                        BorderBrush="{Binding CurrentBrandBorderColor}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CurrentBrandMonogram}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding CurrentBrandAccentColor}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding CurrentBrandWordmark}"
                                                   FontSize="8"
                                                   Foreground="{Binding CurrentBrandAccentColor}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <ScrollViewer Padding="28,24">
                                <StackPanel Spacing="18">
                                    <Border Classes="connectionDialogSurface"
                                            Padding="24">
                                        <StackPanel Spacing="18">
                                            <Grid ColumnDefinitions="120,*"
                                                  ColumnSpacing="18">
                                                <TextBlock Text="连接名称"
                                                           Classes="label"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1"
                                                            Spacing="6">
                                                    <TextBox Text="{Binding ConnectionConfig.Name, Mode=TwoWay}"
                                                             Watermark="请输入连接名称"
                                                             Height="42"
                                                             Classes="modern"
                                                             Classes.error="{Binding IsNameInvalid}" />
                                                    <TextBlock Text="{Binding NameValidationMessage}"
                                                               Classes="validationError"
                                                               IsVisible="{Binding IsNameInvalid}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid IsVisible="{Binding ShowServerFields}"
                                                  ColumnDefinitions="120,*"
                                                  ColumnSpacing="18">
                                                <TextBlock Text="服务器地址"
                                                           Classes="label"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="1"
                                                      ColumnDefinitions="*,150"
                                                      ColumnSpacing="16">
                                                    <StackPanel Grid.Column="0"
                                                                Spacing="6">
                                                        <TextBox Text="{Binding ConnectionConfig.Host, Mode=TwoWay}"
                                                                 Watermark="请输入服务器地址"
                                                                 Height="42"
                                                                 Classes="modern"
                                                                 Classes.error="{Binding IsHostInvalid}" />
                                                        <TextBlock Text="{Binding HostValidationMessage}"
                                                                   Classes="validationError"
                                                                   IsVisible="{Binding IsHostInvalid}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="6">
                                                        <NumericUpDown Value="{Binding ConnectionConfig.Port, Mode=TwoWay}"
                                                                       Height="42"
                                                                       Minimum="1"
                                                                       Maximum="65535"
                                                                       FormatString="0"
                                                                       HorizontalContentAlignment="Center"
                                                                       Classes="modern"
                                                                       Classes.error="{Binding IsPortInvalid}" />
                                                        <TextBlock Text="{Binding PortValidationMessage}"
                                                                   Classes="validationError"
                                                                   IsVisible="{Binding IsPortInvalid}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                            <Grid IsVisible="{Binding ShowCredentialFields}"
                                                  ColumnDefinitions="120,*"
                                                  ColumnSpacing="18">
                                                <TextBlock Text="登录凭据"
                                                           Classes="label"
                                                           VerticalAlignment="Center" />
                                                <Grid Grid.Column="1"
                                                      ColumnDefinitions="*,*"
                                                      ColumnSpacing="16">
                                                    <StackPanel Grid.Column="0"
                                                                Spacing="6"
                                                                IsVisible="{Binding ShowUsernameField}">
                                                        <TextBox Text="{Binding ConnectionConfig.Username, Mode=TwoWay}"
                                                                 Watermark="请输入登录名"
                                                                 Height="42"
                                                                 Classes="modern"
                                                                 Classes.error="{Binding IsUsernameInvalid}"
                                                                 IsEnabled="{Binding !ConnectionConfig.UseWindowsAuthentication}" />
                                                        <TextBlock Text="{Binding UsernameValidationMessage}"
                                                                   Classes="validationError"
                                                                   IsVisible="{Binding IsUsernameInvalid}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="6">
                                                        <TextBox Text="{Binding ConnectionConfig.Password, Mode=TwoWay}"
                                                                 Watermark="请输入密码"
                                                                 Height="42"
                                                                 Classes="modern"
                                                                 Classes.error="{Binding IsPasswordInvalid}"
                                                                 IsEnabled="{Binding !ConnectionConfig.UseWindowsAuthentication}" />
                                                        <TextBlock Text="{Binding PasswordValidationMessage}"
                                                                   Classes="validationError"
                                                                   IsVisible="{Binding IsPasswordInvalid}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <Grid IsVisible="{Binding ShowDatabaseSelector}"
                                                  ColumnDefinitions="120,*"
                                                  ColumnSpacing="18">
                                                <TextBlock Text="默认数据库"
                                                           Classes="label"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1"
                                                            Spacing="6">
                                                    <Grid ColumnDefinitions="*,92"
                                                          ColumnSpacing="10">
                                                        <ComboBox Grid.Column="0"
                                                                  ItemsSource="{Binding AvailableDatabases}"
                                                                  SelectedItem="{Binding ConnectionConfig.Database}"
                                                                  Text="{Binding ConnectionConfig.Database, Mode=TwoWay}"
                                                                  PlaceholderText="请选择默认数据库"
                                                                  IsEditable="True"
                                                                  IsEnabled="{Binding IsDatabaseSelectionEnabled}"
                                                                  Height="42"
                                                                  Classes="modern"
                                                                  Classes.error="{Binding IsDatabaseInvalid}" />
                                                        <Button Grid.Column="1"
                                                                Command="{Binding RefreshDatabasesCommand}"
                                                                IsVisible="{Binding ShowRefreshDatabaseButton}"
                                                                Classes="connectionAction primary"
                                                                Height="42">
                                                            <TextBlock Text="刷新"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Button>
                                                    </Grid>

                                                    <Border IsVisible="{Binding HasAvailableDatabases, Converter={StaticResource InvertedBoolConverter}}"
                                                            Classes="connectionDialogHint"
                                                            Padding="12,10">
                                                        <TextBlock Text="{Binding DatabaseSelectionHint}"
                                                                   Classes="connectionDialogMeta" />
                                                    </Border>

                                                    <TextBlock Text="{Binding DatabaseValidationMessage}"
                                                               Classes="validationError"
                                                               IsVisible="{Binding IsDatabaseInvalid}" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel IsVisible="{Binding ShowWindowsAuthenticationOption}"
                                                        Spacing="8">
                                                <CheckBox IsChecked="{Binding ConnectionConfig.UseWindowsAuthentication, Mode=TwoWay}"
                                                          Content="使用 Windows 身份验证" />
                                                <TextBlock Text="启用后将不再要求填写登录名和密码。"
                                                           Classes="connectionDialogMeta" />
                                            </StackPanel>

                                            <Grid IsVisible="{Binding ShowDatabaseFilePathInput}"
                                                  ColumnDefinitions="120,*"
                                                  ColumnSpacing="18">
                                                <TextBlock Text="数据库文件"
                                                           Classes="label"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1"
                                                            Spacing="6">
                                                    <Grid ColumnDefinitions="*,96"
                                                          ColumnSpacing="10">
                                                        <TextBox Grid.Column="0"
                                                                 Text="{Binding ConnectionConfig.Database, Mode=TwoWay}"
                                                                 Watermark="{Binding DatabaseFilePathHint}"
                                                                 Height="42"
                                                                 Classes="modern"
                                                                 Classes.error="{Binding IsDatabaseInvalid}" />
                                                        <Button Grid.Column="1"
                                                                Click="OnBrowseSqliteFileClick"
                                                                Classes="connectionAction secondary"
                                                                Height="42">
                                                            <TextBlock Text="浏览..."
                                                                       FontWeight="Medium" />
                                                        </Button>
                                                    </Grid>
                                                    <Border Classes="connectionDialogHint"
                                                            Padding="12,10">
                                                        <TextBlock Text="{Binding SQLiteModeHint}"
                                                                   Classes="connectionDialogMeta" />
                                                    </Border>
                                                    <TextBlock Text="{Binding DatabaseValidationMessage}"
                                                               Classes="validationError"
                                                               IsVisible="{Binding IsDatabaseInvalid}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border IsVisible="{Binding HasValidationErrors}"
                                            Classes="connectionDialogErrorBanner"
                                            Padding="16">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="请先修正以下问题"
                                                       Classes="connectionDialogErrorTitle" />
                                            <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   Classes="connectionDialogErrorText"
                                                                   Margin="4,0,0,0" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                        </Grid>
                        <Border Grid.Row="2"
                                Padding="24"
                                Classes="connectionDialogDivider">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button Grid.Column="0"
                                        Command="{Binding TestConnectionCommand}"
                                        IsVisible="{Binding ShowTestButton}"
                                        Classes="connectionAction secondary"
                                        Padding="18,10">
                                    <TextBlock Text="测试连接"
                                               FontWeight="Medium" />
                                </Button>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="12">
                                    <Button Command="{Binding BackToTypeSelectorCommand}"
                                            IsVisible="{Binding ShowBackButton}"
                                            Classes="connectionAction secondary"
                                            Padding="18,10">
                                        <TextBlock Text="上一步"
                                                   FontWeight="Medium" />
                                    </Button>

                                    <Button Command="{Binding ConnectCommand}"
                                            Classes="connectionAction primary"
                                            Padding="22,10">
                                        <TextBlock Text="连接"
                                                   FontWeight="SemiBold" />
                                    </Button>

                                    <Button Command="{Binding SaveCommand}"
                                            Classes="connectionAction secondary"
                                            Padding="22,10">
                                        <TextBlock Text="保存"
                                                   FontWeight="Medium" />
                                    </Button>

                                    <Button Command="{Binding CancelCommand}"
                                            Classes="connectionAction secondary"
                                            Padding="22,10">
                                        <TextBlock Text="取消"
                                                   FontWeight="Medium" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
