<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzrngTools.ViewModels.Database"
             xmlns:models="using:AzrngTools.Models.Database"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="AzrngTools.Views.Database.Workbench.DatabaseTypeSelector"
             x:CompileBindings="False"
             x:DataType="vm:ConnectionDialogViewModel">

    <Design.DataContext>
        <vm:ConnectionDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- 页面标题 -->
        <Border Grid.Row="0" Padding="20,0,20,16">
            <TextBlock Text="选择数据库类型"
                       Classes="heading"/>
        </Border>

        <!-- 数据库类型网格 -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="*,*"
                  Margin="0,0,0,20">

                <!-- 第一行：SQL Server -->
                <Border Grid.Row="0" Grid.Column="0"
                        Classes="dbCard"
                        Tag="SqlServer"
                        Cursor="Hand"
                        x:Name="SqlCard">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <Image Source="/Assets/Database/sqlserver.png"
                               Width="48" Height="48"/>
                        <TextBlock Text="SQL Server"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="Microsoft"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第一行：MySql -->
                <Border Grid.Row="0" Grid.Column="1"
                        Classes="dbCard"
                        Tag="MySql"
                        Cursor="Hand"
                        x:Name="MySqlCard">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <Image Source="/Assets/Database/MySql.png"
                               Width="48" Height="48"/>
                        <TextBlock Text="MySql"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="Oracle"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第一行：PostgresSql -->
                <Border Grid.Row="0" Grid.Column="2"
                        Classes="dbCard"
                        Tag="PostgresSql"
                        Cursor="Hand"
                        x:Name="PostgreCard">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <Image Source="/Assets/Database/PostgresSql.png"
                               Width="48" Height="48"/>
                        <TextBlock Text="PostgresSql"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="PostgresSql Global"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第一行：Sqlite -->
                <Border Grid.Row="0" Grid.Column="3"
                        Classes="dbCard"
                        Tag="Sqlite"
                        Cursor="Hand"
                        x:Name="SqliteCard">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <Image Source="/Assets/Database/Sqlite.png"
                               Width="48" Height="48"/>
                        <TextBlock Text="Sqlite"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="Embedded"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第一行：Oracle -->
                <Border Grid.Row="0" Grid.Column="4"
                        Classes="dbCard"
                        Tag="Oracle"
                        Cursor="Hand"
                        x:Name="OracleCard">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <Image Source="/Assets/Database/oracle.png"
                               Width="48" Height="48"/>
                        <TextBlock Text="Oracle"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="Oracle Corp"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第二行：达梦 -->
                <Border Grid.Row="1" Grid.Column="0"
                        Classes="dbCard"
                        Tag="Dm"
                        Cursor="Hand"
                        x:Name="DamengCard">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <Border Width="48" Height="48"
                                Background="#E74C3C"
                                CornerRadius="8">
                            <TextBlock Text="达"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="达梦"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="武汉达梦"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第二行：DB2 (禁用) -->
                <Border Grid.Row="1" Grid.Column="1"
                        Classes="dbCard dbCardDisabled"
                        Tag="DB2"
                        IsEnabled="False">
                    <StackPanel HorizontalAlignment="Center" Spacing="8" Opacity="0.5">
                        <Border Width="48" Height="48"
                                Background="#95A5A6"
                                CornerRadius="8">
                            <TextBlock Text="DB2"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DB2"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="IBM"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第二行：TiDB (禁用) -->
                <Border Grid.Row="1" Grid.Column="2"
                        Classes="dbCard dbCardDisabled"
                        Tag="TiDB"
                        IsEnabled="False">
                    <StackPanel HorizontalAlignment="Center" Spacing="8" Opacity="0.5">
                        <Border Width="48" Height="48"
                                Background="#E74C3C"
                                CornerRadius="8">
                            <TextBlock Text="Ti"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TiDB"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="PingCAP"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第二行：瀚高 (禁用) -->
                <Border Grid.Row="1" Grid.Column="3"
                        Classes="dbCard dbCardDisabled"
                        Tag="HighGo"
                        IsEnabled="False">
                    <StackPanel HorizontalAlignment="Center" Spacing="8" Opacity="0.5">
                        <Border Width="48" Height="48"
                                Background="#3498DB"
                                CornerRadius="8">
                            <TextBlock Text="瀚"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="瀚高"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="瀚高软件"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>

                <!-- 第二行：人大金仓 (禁用) -->
                <Border Grid.Row="1" Grid.Column="4"
                        Classes="dbCard dbCardDisabled"
                        Tag="Kingbase"
                        IsEnabled="False">
                    <StackPanel HorizontalAlignment="Center" Spacing="8" Opacity="0.5">
                        <Border Width="48" Height="48"
                                Background="#E74C3C"
                                CornerRadius="8">
                            <TextBlock Text="金"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="人大金仓"
                                   Classes="dbCardTitle"/>
                        <TextBlock Text="人大金仓"
                                   Classes="dbCardSubtitle"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
