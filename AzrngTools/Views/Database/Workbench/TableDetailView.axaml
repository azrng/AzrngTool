<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzrngTools.ViewModels.Database"
             xmlns:local="using:AzrngTools.Views.Database.Workbench"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="720"
             x:Class="AzrngTools.Views.Database.Workbench.TableDetailView"
             x:CompileBindings="False">

    <Design.DataContext>
        <vm:TableDetailViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Classes="toolbarStrip"
                IsVisible="{Binding IsLoading}">
            <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource Space.10}">
                <ProgressBar Width="24"
                             Height="18"
                             IsIndeterminate="True" />
                <TextBlock Text="{Binding LoadingText}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Classes="workspaceSurface"
                IsVisible="{Binding ShowEmptyState}">
            <Grid Margin="{StaticResource Thickness.20}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="460"
                            Spacing="{StaticResource Space.12}">
                    <TextBlock Text="暂无表数据"
                               Classes="heading"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="请先在左侧对象树中选择一个架构，以加载该架构下的数据表工作区。"
                               Classes="caption"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="320,16,*"
              IsVisible="{Binding ShowSplitWorkspace}">
            <Border Grid.Column="0"
                    Classes="browserPanel">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Grid.Row="0"
                            Classes="browserCompactSection">
                        <StackPanel Spacing="{StaticResource Space.12}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Space.12}">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Text="数据表列表"
                                               Classes="subheading" />
                                    <TextBlock Text="左侧保留当前架构下的数据表清单，方便快速切换并连续查看字段、索引和 DDL。"
                                               Classes="caption"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Classes="statusPill"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding SchemaName, StringFormat=架构: {0}, TargetNullValue=当前架构}"
                                               Classes="statusPillText" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Classes="browserTreeSurface">
                        <DataGrid ItemsSource="{Binding Tables}"
                                  SelectedItem="{Binding SelectedTable}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称"
                                                    Binding="{Binding Name}"
                                                    Width="180" />
                                <DataGridTextColumn Header="备注"
                                                    Binding="{Binding Comment}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2"
                            Padding="{StaticResource Thickness.12}"
                            BorderBrush="{DynamicResource Brush.Panel.Stroke}"
                            BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="{StaticResource Space.10}">
                            <Button Grid.Column="0"
                                    Command="{Binding RefreshCommand}"
                                    IsEnabled="{Binding SelectedTable, Converter={StaticResource NullToBoolConverter}}"
                                    Classes="workbenchSidebarAction"
                                    HorizontalAlignment="Stretch">
                                <TextBlock Text="刷新详情"
                                           FontWeight="Medium" />
                            </Button>

                            <Button Grid.Column="1"
                                    Command="{Binding ClearCommand}"
                                    Classes="workbenchSidebarAction"
                                    HorizontalAlignment="Stretch">
                                <TextBlock Text="清空"
                                           FontWeight="Medium" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Classes="workspaceSurface">
                <local:TableDetailContent />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Classes="workspaceSurface"
                IsVisible="{Binding ShowDetailOnly}">
            <local:TableDetailContent />
        </Border>
    </Grid>
</UserControl>
