<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzrngTools.ViewModels.Database"
             xmlns:local="using:AzrngTools.Views.Database.Workbench"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="720"
             x:Class="AzrngTools.Views.Database.Workbench.TableDetailView"
             x:CompileBindings="False">

    <Design.DataContext>
        <vm:TableDetailViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Loading bar -->
        <Border Grid.Row="0"
                Padding="12"
                BorderBrush="{DynamicResource BorderLight}"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsLoading}">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
                <ProgressBar Width="24"
                             Height="18"
                             IsIndeterminate="True" />
                <TextBlock Text="{Binding LoadingText}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty state -->
        <Border Grid.Row="1"
                Padding="40"
                IsVisible="{Binding ShowEmptyState}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="暂无表数据"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="请先在左侧对象树中选择一个架构，以加载该架构下的数据表工作区。"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"
                           MaxWidth="420"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Split workspace: table list + detail -->
        <Grid Grid.Row="1"
              ColumnDefinitions="320,16,*"
              IsVisible="{Binding ShowSplitWorkspace}">
            <!-- Table list panel -->
            <Border Grid.Column="0"
                    Classes="card"
                    Padding="0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Grid.Row="0"
                            Padding="16"
                            BorderBrush="{DynamicResource BorderLight}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="数据表"
                                       Classes="subheading" />
                            <TextBlock Text="{Binding SchemaName, StringFormat=架构: {0}}"
                                       Foreground="{DynamicResource TextSecondary}" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Tables}"
                              SelectedItem="{Binding SelectedTable}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称"
                                                Binding="{Binding Name}"
                                                Width="180" />
                            <DataGridTextColumn Header="备注"
                                                Binding="{Binding Comment}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            Padding="16"
                            BorderBrush="{DynamicResource BorderLight}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10">
                            <Button Command="{Binding RefreshCommand}"
                                    IsEnabled="{Binding SelectedTable, Converter={StaticResource NullToBoolConverter}}"
                                    Classes="modern"
                                    HorizontalAlignment="Stretch">
                                <TextBlock Text="刷新详情" />
                            </Button>
                            <Button Command="{Binding ClearCommand}"
                                    Classes="secondary"
                                    HorizontalAlignment="Stretch">
                                <TextBlock Text="清空" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Shared detail content (split mode) -->
            <Border Grid.Column="2"
                    Classes="card"
                    Padding="0">
                <local:TableDetailContent />
            </Border>
        </Grid>

        <!-- Detail-only mode: full-width shared content -->
        <Border Grid.Row="1"
                Padding="0"
                IsVisible="{Binding ShowDetailOnly}">
            <local:TableDetailContent />
        </Border>
    </Grid>
</UserControl>
