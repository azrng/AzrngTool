<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SmartSQL.UI.Views.MessageBox"
        x:CompileBindings="False"
        x:DataType="views:MessageBox"
        xmlns:views="using:SmartSQL.UI.Views"
        Title="确认"
        Width="400"
        Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="false">

    <Grid RowDefinitions="*,Auto" Margin="20">
        <!-- 消息内容 -->
        <StackPanel Grid.Row="0" Spacing="15">
            <!-- 图标和消息 -->
            <Grid ColumnDefinitions="Auto,10,*">
                <TextBlock Grid.Column="0"
                           Text="⚠️"
                           FontSize="32"
                           VerticalAlignment="Top"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding Message}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- 按钮区域 -->
        <Border Grid.Row="1"
                Padding="0,20,0,0"
                BorderBrush="{DynamicResource SystemAccentColor}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                <!-- Yes 按钮 -->
                <Button Content="是"
                        Width="80"
                        Height="32"
                        Command="{Binding YesCommand}"
                        Classes="Primary"
                        IsVisible="{Binding ShowYesButton}"/>
                <!-- No 按钮 -->
                <Button Content="否"
                        Width="80"
                        Height="32"
                        Command="{Binding NoCommand}"
                        IsVisible="{Binding ShowNoButton}"/>
                <!-- OK 按钮 -->
                <Button Content="确定"
                        Width="80"
                        Height="32"
                        Command="{Binding OkCommand}"
                        Classes="Primary"
                        IsVisible="{Binding ShowOkButton}"/>
                <!-- Cancel 按钮 -->
                <Button Content="取消"
                        Width="80"
                        Height="32"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding ShowCancelButton}"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
