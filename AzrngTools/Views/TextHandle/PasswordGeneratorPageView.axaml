<UserControl
    d:DesignHeight="760"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="AzrngTools.Views.TextHandle.PasswordGeneratorPageView"
    x:DataType="textHandle:PasswordGeneratorPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:textHandle="clr-namespace:AzrngTools.ViewModels.TextHandle"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource Thickness.15}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
            <Border Grid.Row="0" Classes="tool-card-roomy">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.12}">
                    <StackPanel Spacing="{StaticResource Space.4}">
                        <TextBlock Classes="section-title" Text="密码与随机字符串生成器" />
                        <TextBlock Classes="section-copy" Text="把配置、单个结果和批量结果拆成三个明确区域，既能快速生成一个密码，也方便批量导出。" />
                    </StackPanel>

                    <Border Grid.Column="1" Classes="badge-pill">
                        <TextBlock Classes="badge-text" Text="{Binding PasswordStrength, FallbackValue=未生成}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="0.95*,1.05*" ColumnSpacing="{StaticResource Space.12}">
                <Border Grid.Column="0" Classes="tool-card-roomy">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.12}">
                        <StackPanel Spacing="{StaticResource Space.4}">
                            <TextBlock Classes="section-title" Text="生成配置" />
                            <TextBlock Classes="section-copy" Text="长度、批量数量和字符类型集中在同一块，生成前先确认这一部分即可。" />
                        </StackPanel>

                        <Border Grid.Row="1" Classes="tool-card-soft">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="{StaticResource Space.16}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.10}">
                                <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                    <TextBlock Classes="metric-label" VerticalAlignment="Center" Text="长度" />
                                    <NumericUpDown
                                        Grid.Column="1"
                                        Maximum="128"
                                        Minimum="4"
                                        Value="{Binding PasswordLength}" />
                                </Grid>

                                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                    <TextBlock Classes="metric-label" VerticalAlignment="Center" Text="批量数量" />
                                    <NumericUpDown
                                        Grid.Column="1"
                                        Maximum="100"
                                        Minimum="1"
                                        Value="{Binding BatchCount}" />
                                </Grid>

                                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource Space.10}">
                                    <TextBlock Classes="metric-label" VerticalAlignment="Top" Text="字符类型" />
                                    <Grid Grid.Column="1" ColumnDefinitions="*,*" ColumnSpacing="{StaticResource Space.16}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.8}">
                                        <CheckBox Content="包含数字 (0-9)" IsChecked="{Binding IncludeNumbers}" />
                                        <CheckBox Grid.Column="1" Content="包含小写字母 (a-z)" IsChecked="{Binding IncludeLowercase}" />
                                        <CheckBox Grid.Row="1" Content="包含大写字母 (A-Z)" IsChecked="{Binding IncludeUppercase}" />
                                        <CheckBox Grid.Row="1" Grid.Column="1" Content="包含特殊字符 (!@#$%...)" IsChecked="{Binding IncludeSpecialChars}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Classes="tool-card-soft">
                            <StackPanel Spacing="{StaticResource Space.8}">
                                <TextBlock Classes="metric-label" Text="提示" />
                                <TextBlock Classes="Small" Text="• 单个结果和批量结果共用同一套配置" />
                                <TextBlock Classes="Small" Text="• 强度标签会在生成单个密码后自动刷新" />
                                <TextBlock Classes="Small" Text="• 批量生成数量建议控制在 1 到 100 之间" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource Space.12}">
                    <Border Grid.Row="0" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space.10}">
                                <StackPanel Spacing="{StaticResource Space.4}">
                                    <TextBlock Classes="section-title" Text="单个结果" />
                                    <TextBlock Classes="section-copy" Text="适合快速生成一个密码、随机数或随机字符串，并立即复制。" />
                                </StackPanel>
                                <Border Grid.Column="1" Classes="badge-pill compact" VerticalAlignment="Top">
                                    <TextBlock Classes="badge-text" Text="{Binding PasswordStrength, FallbackValue=未生成}" />
                                </Border>
                            </Grid>

                            <WrapPanel Grid.Row="1" Classes="tool-actions">
                                <Button
                                    Command="{Binding GeneratePasswordCommand}"
                                    Content="生成密码"
                                    Theme="{DynamicResource SolidButton}" />
                                <Button
                                    Command="{Binding GenerateRandomNumberCommand}"
                                    Content="生成随机数"
                                    Theme="{DynamicResource OutlineButton}" />
                                <Button
                                    Command="{Binding GenerateRandomStringCommand}"
                                    Content="生成随机字符串"
                                    Theme="{DynamicResource OutlineButton}" />
                            </WrapPanel>

                            <Border Grid.Row="2" Classes="tool-card-soft">
                                <TextBox
                                    AcceptsReturn="True"
                                    Background="{DynamicResource Brush.Surface.Transparent}"
                                    BorderThickness="0"
                                    Classes="Standard"
                                    FontFamily="Consolas,monospace"
                                    Height="{StaticResource Layout.Avatar.Md}"
                                    IsReadOnly="True"
                                    Text="{Binding GeneratedPassword}"
                                    TextWrapping="Wrap"
                                    PlaceholderText="生成结果会显示在这里" />
                            </Border>

                            <WrapPanel Grid.Row="3" Classes="tool-actions" HorizontalAlignment="Right">
                                <Button
                                    Command="{Binding CopyPasswordCommand}"
                                    Content="复制结果"
                                    Theme="{DynamicResource OutlineButton}" />
                                <Button
                                    Command="{Binding ClearCommand}"
                                    Content="清空结果"
                                    Theme="{DynamicResource OutlineButton}" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Classes="tool-card-roomy">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="{StaticResource Space.10}">
                            <StackPanel Spacing="{StaticResource Space.4}">
                                <TextBlock Classes="section-title" Text="批量结果" />
                                <TextBlock Classes="section-copy" Text="用于一次性生成多条密码并统一复制，列表展示采用等宽字体，便于快速浏览。" />
                            </StackPanel>

                            <WrapPanel Grid.Row="1" Classes="tool-actions">
                                <Button
                                    Command="{Binding GenerateBatchPasswordsCommand}"
                                    Content="批量生成"
                                    Theme="{DynamicResource SolidButton}" />
                                <Button
                                    Command="{Binding CopyAllPasswordsCommand}"
                                    Content="复制全部"
                                    Theme="{DynamicResource OutlineButton}" />
                                <Button
                                    Command="{Binding ClearBatchCommand}"
                                    Content="清空列表"
                                    Theme="{DynamicResource OutlineButton}" />
                            </WrapPanel>

                            <Border Grid.Row="2" Classes="tool-card-soft">
                                <ScrollViewer Height="300">
                                    <ItemsControl ItemsSource="{Binding GeneratedPasswords}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource Brush.Border.Divider}" BorderThickness="0,0,0,1" Padding="{StaticResource Thickness.0.8}">
                                                    <TextBlock
                                                        FontFamily="Consolas,monospace"
                                                        Text="{Binding}"
                                                        TextWrapping="Wrap" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
